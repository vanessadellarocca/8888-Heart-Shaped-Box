@dataclass
class DaoBreathState:
    radius: float = R_OUTER
    lower_live: float = DAO_CENTER - PHI
    upper_live: float = DAO_CENTER + PHI
    midpoint: float = DAO_CENTER
    center_trace: float = DAO_TRACE_CENTER
    phase: float = 0.0
    lower_target: float = DAO_CENTER - (R_OUTER + EPSILON)
    upper_target: float = DAO_CENTER + (R_OUTER - EPSILON)
    inner_turn: float = 0.0
    dao_score: float = 0.0
    under6_score: float = 0.0
    split_risk: float = 0.0
    radius_velocity: float = 0.0


@dataclass
class DaoBreath:
    state: DaoBreathState = field(default_factory=DaoBreathState)

    def targets(self, radius: float) -> Tuple[float, float, float]:
        lower = DAO_CENTER - (radius + EPSILON)
        upper = DAO_CENTER + (radius - EPSILON)
        mid = (lower + upper) / 2.0
        return lower, upper, mid

    def step(
        self,
        center_cross_event: float,
        edge_braid: float,
        inward_pull: float,
        reflection_feedback: float = 0.0,
    ) -> Dict[str, Any]:
        s = self.state

        # Core-Kontakt erzeugt die Radius-Kontraktion.
        # Edge-Braid verstärkt sie, weil verschränkte Ränder Außeninversion verhindern.
        braid_gain = clamp01(0.5 * PHI + 0.5 * edge_braid)
        inward_gain = clamp01(0.5 * inward_pull + 0.5 * reflection_feedback)
        contraction = clamp01(center_cross_event * (0.70 + 0.30 * braid_gain) + 0.15 * inward_gain)

        target_radius = R_INNER + (R_OUTER - R_INNER) * (1.0 - contraction)
        target_radius = max(R_INNER, min(R_OUTER, target_radius))

        old_radius = s.radius
        s.radius = lerp(s.radius, target_radius, CORE_TRACK_RATE)
        s.radius_velocity = s.radius - old_radius

        s.lower_target, s.upper_target, _target_mid = self.targets(s.radius)
        s.lower_live = lerp(s.lower_live, s.lower_target, CORE_TRACK_RATE)
        s.upper_live = lerp(s.upper_live, s.upper_target, CORE_TRACK_RATE)
        s.midpoint = (s.lower_live + s.upper_live) / 2.0
        s.center_trace = DAO_TRACE_CENTER

        s.inner_turn = score_close(s.radius, R_INNER, PHI)
        s.under6_score = score_close(s.midpoint, DAO_TRACE_CENTER, PHI)
        s.split_risk = clamp01(abs(s.midpoint - DAO_CENTER) / PHI * (1.0 - s.under6_score))
        s.dao_score = safe_geomean([
            s.under6_score + EPSILON,
            1.0 - s.split_risk + EPSILON,
            1.0 - abs(s.radius - target_radius) / PHI + EPSILON,
            contraction + EPSILON,
        ])

        # Phase bleibt Atem, aber nicht Ursache.
        s.phase = (s.phase + CENTER_RATE * (0.5 + 0.5 * s.dao_score)) % 1.0

        return {
            "state": asdict(s),
            "meaning": (
                "DAO-6 ist Atemraum: Core-Kontakt zieht den Radius nach innen; "
                "die Spur bleibt 6-epsilon, ohne 6 hart zu setzen."
            ),
        }


