    lower_arc_roles: Dict[str, str] = field(default_factory=lambda: {
        "1": "Pluto/Mars — Grenzfeuer, Transformation, Geburtskante",
        "8": "Mars/Pluto — Tiefenfeuer, Regeneration, Schwellenmacht",
    })
    upper_arc_roles: Dict[str, str] = field(default_factory=lambda: {
        "2": "Venus geometrisch — Form, Bindung, Gestalt",
        "7": "Venus dynamisch — Antwort, Bewegung, Begegnung",
    })


@dataclass
class HeartArcs:
    state: HeartArcState = field(default_factory=HeartArcState)

    def step(
        self,
        center_cross_event: float,
        edge_braid: float,
        membrane_release: float,
        dao_score: float,
    ) -> Dict[str, Any]:
        s = self.state

        # Der alte 1↔8-Zug wird nicht abgeschnitten, sondern gebogen.
        lower_target = safe_geomean([
            center_cross_event + EPSILON,
            edge_braid + EPSILON,
            dao_score + EPSILON,
        ])
        s.lower_arc_1_8 = lerp(s.lower_arc_1_8, lower_target, EDGE_RATE)
        s.mars_pluto_transform = s.lower_arc_1_8

        # 2↔7 gibt Form und Kontaktfähigkeit.
        upper_target = safe_geomean([
            membrane_release + EPSILON,
            edge_braid + EPSILON,
            phi_ratio_score(center_cross_event + EPSILON, membrane_release + EPSILON) + EPSILON,
        ])
        s.upper_arc_2_7 = lerp(s.upper_arc_2_7, upper_target, EDGE_RATE)
        s.venus_contact_form = s.upper_arc_2_7

        s.return_force = safe_geomean([
            s.lower_arc_1_8 + EPSILON,
            s.upper_arc_2_7 + EPSILON,
            edge_braid + EPSILON,
        ])
        s.arc_score = safe_geomean([
            s.return_force + EPSILON,
            s.mars_pluto_transform + EPSILON,
            s.venus_contact_form + EPSILON,
        ])

        return {"state": asdict(s)}


