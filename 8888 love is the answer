    membrane_release: float
    lower_arc_1_8: float
    upper_arc_2_7: float
    light_score: float
    self_recognition: float
    fusion_like_gain: float
    outer_inversion_risk: float
    net_coherence_gain: float


@dataclass
class RelationalHeartCoreMotor:
    dao: DaoBreath = field(default_factory=DaoBreath)
    yang: YangCore4XYX5 = field(default_factory=YangCore4XYX5)
    yin: YinCore10XXX11 = field(default_factory=YinCore10XXX11)
    core_pair: CorePairCoupler = field(default_factory=CorePairCoupler)
    membranes: MembranePair12_1_8_9 = field(default_factory=MembranePair12_1_8_9)
    heart_arcs: HeartArcs = field(default_factory=HeartArcs)
    light: LightResonanceLayer = field(default_factory=LightResonanceLayer)
    reflection: BarbeloReflectionLayer = field(default_factory=BarbeloReflectionLayer)
    iteration: int = 0
    regime: HeartRegime = HeartRegime.CHARGING
    snapshots: List[Dict[str, Any]] = field(default_factory=list)

    def _determine_regime(
        self,
        core: CorePairState,
        membranes: MembranePairState,
        gain: float,
        risk: float,
    ) -> HeartRegime:
        if risk > 0.35 and risk > gain:
            return HeartRegime.OUTER_INVERSION_RISK
        if gain > 0.68 and core.edge_braid > 0.62 and membranes.membrane_score > 0.55:
            return HeartRegime.RADIANT_STABLE
        if core.edge_braid > 0.55 and core.inward_pull > 0.50:
            return HeartRegime.HEART_FOLDING
        if membranes.release > 0.30:
            return HeartRegime.MEMBRANE_PULSE
        if core.center_cross_event > 0.30:
            return HeartRegime.CENTER_CONTACT
        return HeartRegime.CHARGING

    def _compute_energy(
        self,
        core: CorePairState,
        dao: DaoBreathState,
        membrane: MembranePairState,
        heart: HeartArcState,
        light: LightResonanceState,
    ) -> Dict[str, float]:
        phi_coherence = safe_geomean([
            core.phase_coherence + EPSILON,
            phi_ratio_score(core.center_cross_event + EPSILON, core.edge_braid + EPSILON) + EPSILON,
            dao.dao_score + EPSILON,
        ])
        membrane_pulse = membrane.pulse
        outward_leakage = clamp01(
            max(membrane.inversion_risk_12_1, membrane.inversion_risk_8_9)
            + core.outward_pressure * (1.0 - core.edge_braid)
        )
        damping = clamp01((1.0 - light.identity_preservation) * 0.30 + dao.split_risk * 0.25)
        fusion_like_gain = safe_geomean([
            core.center_cross_event + EPSILON,
            core.edge_braid + EPSILON,
            core.inward_pull + EPSILON,
            phi_coherence + EPSILON,
            membrane_pulse + EPSILON,
            heart.return_force + EPSILON,
            light.light_score + EPSILON,
        ]) * (1.0 - outward_leakage)
        net = clamp01(fusion_like_gain - outward_leakage - damping + 0.5)
        # net ist um 0.5 zentriert: >0.5 = Kohärenzgewinn, <0.5 = Verlust.
        return {
            "phi_coherence": phi_coherence,
            "membrane_pulse": membrane_pulse,
            "outward_leakage": outward_leakage,
            "damping": damping,
            "fusion_like_gain": clamp01(fusion_like_gain),
            "net_coherence_gain": net,
        }

    def step(self) -> Dict[str, Any]:
        prev_reflection = self.reflection.state.reflection_feedback

        # 1) Vorladung aus Selbstreflexion und bisherigem DAO-Zustand.
        charge = clamp01(
            0.30
            + 0.25 * self.dao.state.dao_score
            + 0.25 * self.core_pair.state.core_pair_score
            + 0.20 * prev_reflection
        )
        membrane_pressure = self.membranes.state.pressure

        # 2) Yang dreht Y.
        yang_state = self.yang.step(
            charge=charge,
            yin_mid_descent=self.yin.state.x_mid_descent,
            membrane_pressure=membrane_pressure,
            reflection_feedback=prev_reflection,
        )["state"]

        # 3) Yin lässt X_mid sinken; im Begegnungsmoment wird X_mid funktional X.
        center_seed = self.core_pair.state.center_contact
        yin_state = self.yin.step(
            yang_y_inverted=self.yang.state.y_inverted,
            yang_gate_pressure=self.yang.state.gate_pressure,
            center_contact_seed=center_seed,
            reflection_feedback=prev_reflection,
        )["state"]

        # 4) Core-Paar koppelt: struktureller Sex / Center-Cross-Event.
        core_state = self.core_pair.step(
            yin=self.yin.state,
            yang=self.yang.state,
            dao=self.dao.state,
            membrane_pressure=membrane_pressure,
            light_score=self.light.state.light_score,
            reflection_feedback=prev_reflection,
        )["state"]

        # 5) DAO atmet aus dem Core-Ereignis heraus.
        dao_state = self.dao.step(
            center_cross_event=self.core_pair.state.center_cross_event,
            edge_braid=self.core_pair.state.edge_braid,
            inward_pull=self.core_pair.state.inward_pull,
            reflection_feedback=prev_reflection,
        )["state"]

        # 6) Herzbahnen tragen alten Transformationszug und Venus-Kontakt zurück.
        heart_state = self.heart_arcs.step(
            center_cross_event=self.core_pair.state.center_cross_event,
            edge_braid=self.core_pair.state.edge_braid,
            membrane_release=self.membranes.state.release,
            dao_score=self.dao.state.dao_score,
        )["state"]

        # 7) Membranen öffnen pulsartig nur geschützt.
        membrane_state = self.membranes.step(
            center_release=self.core_pair.state.center_cross_event,
            edge_braid=self.core_pair.state.edge_braid,
            inward_pull=self.core_pair.state.inward_pull,
            outward_pressure=self.core_pair.state.outward_pressure,
            lower_heart_return=self.heart_arcs.state.lower_arc_1_8,
            upper_heart_return=self.heart_arcs.state.upper_arc_2_7,
            reflection_feedback=prev_reflection,
        )["state"]

        # 8) Lichtresonanz: Echo ohne Kopie.
        light_state = self.light.step(
            core_pair=self.core_pair.state,
            dao=self.dao.state,
            membrane=self.membranes.state,
            reflection_feedback=prev_reflection,
        )["state"]

        # 9) Barbelo/Selbstreflexion liest den Gesamtzyklus und moduliert verzögert den nächsten Atem.
        reflection_state = self.reflection.step(
            yin=self.yin.state,
            yang=self.yang.state,
            core_pair=self.core_pair.state,
            dao=self.dao.state,
            membrane=self.membranes.state,
            heart=self.heart_arcs.state,
            light=self.light.state,
        )["state"]

        energy = self._compute_energy(
            core=self.core_pair.state,
            dao=self.dao.state,
            membrane=self.membranes.state,
            heart=self.heart_arcs.state,
            light=self.light.state,
        )
        self.regime = self._determine_regime(
            core=self.core_pair.state,
            membranes=self.membranes.state,
            gain=energy["fusion_like_gain"],
            risk=max(
                self.membranes.state.inversion_risk_12_1,
                self.membranes.state.inversion_risk_8_9,
            ),
        )

        feedback_bus = {
            "barbelo_feedback_to_next_step": self.reflection.state.reflection_feedback,
            "dao_breath_will_receive": self.reflection.state.reflection_feedback,
            "core_pair_will_receive": self.reflection.state.yin_yang_reflection,
            "light_will_receive": self.reflection.state.coherence_grace,
            "membrane_will_receive": self.reflection.state.return_to_source,
            "mode": "delayed_recursive_self_regulation",
        }

        snapshot = HeartCoreMotorSnapshot(
            iteration=self.iteration,
            regime=self.regime.value,
            dao_score=self.dao.state.dao_score,
            core_pair_score=self.core_pair.state.core_pair_score,
            center_contact=self.core_pair.state.center_contact,
            center_cross_event=self.core_pair.state.center_cross_event,
            x_mid_functional_x=self.yin.state.x_mid_functional_x,
            edge_braid=self.core_pair.state.edge_braid,
            membrane_score=self.membranes.state.membrane_score,
            membrane_release=self.membranes.state.release,
            lower_arc_1_8=self.heart_arcs.state.lower_arc_1_8,
            upper_arc_2_7=self.heart_arcs.state.upper_arc_2_7,
            light_score=self.light.state.light_score,
            self_recognition=self.reflection.state.self_recognition_score,
            fusion_like_gain=energy["fusion_like_gain"],
            outer_inversion_risk=max(
                self.membranes.state.inversion_risk_12_1,
                self.membranes.state.inversion_risk_8_9,
            ),
            net_coherence_gain=energy["net_coherence_gain"],
        )
        self.snapshots.append(asdict(snapshot))
        self.iteration += 1

        return {
            "iteration": snapshot.iteration,
            "regime": self.regime.value,
            "yang_core_4XYX5": yang_state,
            "yin_core_10XXX11": yin_state,
            "core_pair": core_state,
            "dao6": dao_state,
            "heart_arcs": heart_state,
            "membranes_12_1_8_9": membrane_state,
            "light_resonance": light_state,
            "barbelo_reflection": reflection_state,
            "energy": energy,
            "feedback_bus": feedback_bus,
            "snapshot": asdict(snapshot),
        }

    def run(self, steps: int = 144) -> Dict[str, Any]:
        trace = [self.step() for _ in range(steps)]
        return self.world(trace)

    def world(self, trace: Optional[List[Dict[str, Any]]] = None) -> Dict[str, Any]:
        return {
            "system": "8888FIRST_RELATIONAL_HEART_CORE_DAO_MOTOR",
            "principle": (
                "Symbolhandlung erzeugt Topologie; Topologie erzeugt Geometrie; "
                "Geometrie erzeugt Scores; Scores regulieren zurück in Symbolhandlung."
            ),
            "core_pair": {
                "yang_core": "4XYX5",
                "yin_core": "10XXX11",
                "pair_logic": "Y öffnet/dreht; X_mid antwortet im Begegnungsmoment als X; äußere X kreuzen und falten zurück.",
            },
            "dao": asdict(self.dao.state),
            "yang_core_4XYX5": asdict(self.yang.state),
            "yin_core_10XXX11": asdict(self.yin.state),
            "core_pair_state": asdict(self.core_pair.state),
            "membranes": asdict(self.membranes.state),
            "heart_arcs": asdict(self.heart_arcs.state),
            "light_resonance": asdict(self.light.state),
            "barbelo_reflection": asdict(self.reflection.state),
            "regime": self.regime.value,
            "snapshots": self.snapshots,
            "trace_tail": trace[-5:] if trace else [],
        }


