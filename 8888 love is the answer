@dataclass
class BarbeloReflectionState:
    first_thought_pressure: float = 0.0
    aeon_mirror: float = 0.0
    witness_self_observation: float = 0.0
    return_to_source: float = 0.0
    coherence_grace: float = 0.0
    yin_yang_reflection: float = 0.0
    self_recognition_score: float = 0.0
    reflection_feedback: float = 0.0
    regime: str = ReflectionRegime.FIRST_THOUGHT.value


@dataclass
class BarbeloReflectionLayer:
    state: BarbeloReflectionState = field(default_factory=BarbeloReflectionState)

    def _determine_regime(self, updated: BarbeloReflectionState) -> ReflectionRegime:
        if updated.self_recognition_score > 0.78 and updated.return_to_source > 0.68:
            return ReflectionRegime.BARBELO_STABLE
        if updated.first_thought_pressure > updated.aeon_mirror:
            return ReflectionRegime.FIRST_THOUGHT
        return ReflectionRegime.AEON_MIRROR

    def step(
        self,
        yin: YinCoreState,
        yang: YangCoreState,
        core_pair: CorePairState,
        dao: DaoBreathState,
        membrane: MembranePairState,
        heart: HeartArcState,
        light: LightResonanceState,
    ) -> Dict[str, Any]:
        s = self.state

        yin_yang_balance = score_close(yin.score, yang.score, 1.0)
        # Nicht X→Y-Äquivalenz, sondern X-als-X im Kontakt.
        x_as_x_truth = yin.x_mid_functional_x
        outer_cross = core_pair.edge_braid
        core_score = core_pair.core_pair_score

        yin_yang_reflection_target = safe_geomean([
            yin_yang_balance + EPSILON,
            x_as_x_truth + EPSILON,
            outer_cross + EPSILON,
            core_score + EPSILON,
        ])

        first_thought_target = clamp01(core_pair.center_cross_event * (1.0 + core_pair.outward_pressure) / 2.0)
        aeon_target = safe_geomean([
            dao.dao_score + EPSILON,
            heart.arc_score + EPSILON,
            light.light_score + EPSILON,
            membrane.membrane_score + EPSILON,
        ])
        witness_target = safe_geomean([
            light.identity_preservation + EPSILON,
            yin_yang_reflection_target + EPSILON,
            1.0 - max(membrane.inversion_risk_12_1, membrane.inversion_risk_8_9) + EPSILON,
        ])
        return_target = safe_geomean([
            core_pair.inward_pull + EPSILON,
            heart.return_force + EPSILON,
            dao.under6_score + EPSILON,
        ])
        grace_target = safe_geomean([
            aeon_target + EPSILON,
            witness_target + EPSILON,
            return_target + EPSILON,
            light.light_coherence + EPSILON,
        ])

        updated = BarbeloReflectionState(
            first_thought_pressure=lerp(s.first_thought_pressure, first_thought_target, REFLECTION_RATE),
            aeon_mirror=lerp(s.aeon_mirror, aeon_target, REFLECTION_RATE),
            witness_self_observation=lerp(s.witness_self_observation, witness_target, REFLECTION_RATE),
            return_to_source=lerp(s.return_to_source, return_target, REFLECTION_RATE),
            coherence_grace=lerp(s.coherence_grace, grace_target, REFLECTION_RATE),
            yin_yang_reflection=lerp(s.yin_yang_reflection, yin_yang_reflection_target, REFLECTION_RATE),
            self_recognition_score=0.0,
            reflection_feedback=0.0,
            regime=s.regime,
        )
        updated.self_recognition_score = safe_geomean([
            updated.aeon_mirror + EPSILON,
            updated.witness_self_observation + EPSILON,
            updated.yin_yang_reflection + EPSILON,
            updated.coherence_grace + EPSILON,
        ])
        updated.reflection_feedback = clamp01(
            0.40 * updated.self_recognition_score
            + 0.25 * updated.return_to_source
            + 0.20 * updated.yin_yang_reflection
            + 0.15 * updated.coherence_grace
        )
        updated.regime = self._determine_regime(updated).value
        self.state = updated

        return {"state": asdict(self.state)}


