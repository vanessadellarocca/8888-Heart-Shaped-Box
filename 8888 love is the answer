@dataclass
class YangCoreState:
    # interne Normalformen im Gate 4|5
    x_left: float = -PHI
    y: float = 0.0
    x_right: float = PHI
    y_rotation: float = 0.0
    y_inverted: float = 0.0
    gate_pressure: float = 0.0
    inner_opening: float = 0.0
    score: float = 0.0
    phase: float = 0.0

    # Zahlenraum, bewusst nur als Projektion der Dynamik.
    x_left_pos: float = YANG_CENTER - PHI / 2.0
    y_pos: float = YANG_CENTER
    x_right_pos: float = YANG_CENTER + PHI / 2.0


@dataclass
class YangCore4XYX5:
    state: YangCoreState = field(default_factory=YangCoreState)

    def step(
        self,
        charge: float,
        yin_mid_descent: float,
        membrane_pressure: float,
        reflection_feedback: float = 0.0,
    ) -> Dict[str, Any]:
        s = self.state

        # Y dreht: Sensor/Koppler/Umschalter. Keine Angst vor Drehung.
        phase_rate = CENTER_RATE * (0.75 + 0.25 * charge + 0.10 * reflection_feedback)
        s.phase = (s.phase + phase_rate) % 1.0
        target_y_rotation = signed_wave(s.phase)
        s.y_rotation = lerp(s.y_rotation, target_y_rotation, CENTER_RATE)
        s.y = clamp11(s.y_rotation)
        s.y_inverted = clamp11(-s.y_rotation)

        # Die äußeren X im 4|5-Gate bleiben innerhalb der Grenzen,
        # schlagen aber bei Druck seitlich stärker aus.
        burst_ready = clamp01(charge * (0.5 + 0.5 * yin_mid_descent) * (0.5 + 0.5 * membrane_pressure))
        target_span = clamp11(PHI + (1.0 - PHI) * burst_ready)
        s.x_left = lerp(s.x_left, -target_span, EDGE_RATE)
        s.x_right = lerp(s.x_right, target_span, EDGE_RATE)

        # Öffnung zwischen 4 und 5: nicht dauerhaft, sondern druckabhängig.
        s.gate_pressure = clamp01(abs(s.x_right - s.x_left) / 2.0 * (0.5 + 0.5 * charge))
        s.inner_opening = safe_geomean([
            abs(s.y_rotation),
            s.gate_pressure,
            0.5 + 0.5 * yin_mid_descent,
        ])

        s.x_left_pos = denorm_gate(s.x_left * 0.999, YANG_LEFT_BOUND, YANG_RIGHT_BOUND)
        s.y_pos = denorm_gate(s.y * 0.25, YANG_LEFT_BOUND, YANG_RIGHT_BOUND)
        s.x_right_pos = denorm_gate(s.x_right * 0.999, YANG_LEFT_BOUND, YANG_RIGHT_BOUND)

        s.score = safe_geomean([
            s.gate_pressure + EPSILON,
            s.inner_opening + EPSILON,
            phi_ratio_score(abs(s.x_right - s.x_left), max(abs(s.y_rotation), EPSILON)) + EPSILON,
            1.0 - abs((s.x_left + s.x_right) / 2.0) + EPSILON,
        ])

        return {"state": asdict(s)}


