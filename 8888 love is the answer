# ============================================================
# 0) KONSTANTEN
# ============================================================

PHI = 0.618033988749895          # kleines Phi
PHI_BIG = 1.0 / PHI              # großes Phi ≈ 1.618
PHI2 = PHI * PHI                 # ≈ 0.382
EPSILON = 1.0 / 137.0            # lebendige Nicht-Kollaps-Differenz
EPS = 1e-12

MOD = 12.0
DAO_CENTER = 6.0
DAO_TRACE_CENTER = DAO_CENTER - EPSILON
R_OUTER = PHI
R_INNER = EPSILON

# Phasenraten: Zentrum schneller, Ränder verzögert, Membran tiefer verzögert.
CENTER_RATE = PHI / 5.0
CORE_TRACK_RATE = PHI / 8.0
EDGE_RATE = PHI2 / 5.0
MEMBRANE_RATE = PHI2 / 8.0
REFLECTION_RATE = PHI / 13.0
LIGHT_RATE = PHI / 8.0

# Core-Orte als symbolische Zahlenräume.
YANG_LEFT_BOUND = 4.0
YANG_RIGHT_BOUND = 5.0
YANG_CENTER = 4.5
YIN_LEFT_BOUND = 10.0
YIN_RIGHT_BOUND = 11.0
YIN_CENTER = 10.5

# Herzbahnen.
LOWER_HEART_ARC = (1.0, 8.0)     # Pluto/Mars ↔ Mars/Pluto
UPPER_HEART_ARC = (2.0, 7.0)     # Venus geometrisch ↔ Venus dynamisch


# ============================================================
# 1) HILFSFUNKTIONEN
# ============================================================

def clamp01(x: float) -> float:
    return max(0.0, min(1.0, float(x)))


def clamp11(x: float) -> float:
    return max(-1.0, min(1.0, float(x)))


def lerp(a: float, b: float, t: float) -> float:
    t = clamp01(t)
    return (1.0 - t) * float(a) + t * float(b)


def wrap_mod(x: float, mod: float = MOD) -> float:
    x = float(x) % mod
    return x if x >= 0.0 else x + mod


def signed_circular_delta(current: float, target: float, mod: float = MOD) -> float:
    delta = (target - current) % mod
    if delta > mod / 2.0:
        delta -= mod
    return delta


def circular_distance(a: float, b: float, mod: float = MOD) -> float:
    diff = abs((float(a) - float(b)) % mod)
    return min(diff, mod - diff)


def score_close(a: float, b: float, scale: float = 1.0) -> float:
    scale = max(abs(scale), EPS)
    return clamp01(1.0 - abs(float(a) - float(b)) / scale)


def circular_score_close(a: float, b: float, scale: float = 1.0, mod: float = MOD) -> float:
    return clamp01(1.0 - circular_distance(a, b, mod) / max(scale, EPS))


def safe_geomean(values: List[float]) -> float:
    vals = [clamp01(v) for v in values]
    if not vals:
        return 0.0
    acc = 1.0
    for v in vals:
        acc *= max(v, EPS)
    return clamp01(acc ** (1.0 / len(vals)))


def safe_mean(values: List[float]) -> float:
    return sum(values) / len(values) if values else 0.0


def smooth_pulse(phase: float) -> float:
    """0→1→0. Reiner Atem ohne harte Kante."""
    return 0.5 - 0.5 * math.cos(2.0 * math.pi * phase)


def signed_wave(phase: float) -> float:
    return math.sin(2.0 * math.pi * phase)


def anti_collapse(x: float, floor: float = EPSILON) -> float:
    """Hält eine Dynamik lebendig, ohne sie hart zu setzen."""
    return max(floor, float(x))


def norm_gate(value: float, left: float, right: float) -> float:
    """Zahlenraum → [-1, 1] relativ zum Gate."""
    center = (left + right) / 2.0
    half = max(abs(right - left) / 2.0, EPS)
    return clamp11((value - center) / half)


def denorm_gate(norm: float, left: float, right: float) -> float:
    """[-1, 1] → Zahlenraum."""
    center = (left + right) / 2.0
    half = max(abs(right - left) / 2.0, EPS)
    return center + clamp11(norm) * half


def phi_ratio_score(a: float, b: float) -> float:
    """Prüft, ob zwei positive Größen im Phi-Verhältnis stehen."""
    a = abs(a)
    b = abs(b)
    if a < EPS or b < EPS:
        return 0.0
    r = min(a / b, b / a)
    return clamp01(1.0 - abs(r - PHI) / PHI)


