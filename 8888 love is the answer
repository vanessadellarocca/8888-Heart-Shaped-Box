# 5) YIN-CORE 10XXX11
# ============================================================

@dataclass
class YinCoreState:
    # interne Normalformen im Gate 10|11
    x_left: float = -PHI
    x_mid: float = 0.0
    x_right: float = PHI

    # Wichtig: X_mid ist vor dem Kontakt eng pendelnd/blockiert.
    # Im Begegnungsmoment wird es funktional X.
    x_mid_descent: float = 0.0
    x_mid_cross_activation: float = 0.0
    x_mid_functional_x: float = 0.0

    core_pressure: float = 0.0
    score: float = 0.0
    phase: float = 0.5

    x_left_pos: float = YIN_CENTER - PHI / 2.0
    x_mid_pos: float = YIN_CENTER
    x_right_pos: float = YIN_CENTER + PHI / 2.0


@dataclass
class YinCore10XXX11:
    state: YinCoreState = field(default_factory=YinCoreState)

    def step(
        self,
        yang_y_inverted: float,
        yang_gate_pressure: float,
        center_contact_seed: float,
        reflection_feedback: float = 0.0,
    ) -> Dict[str, Any]:
        s = self.state

        # X_mid sinkt aus dem oberen Core in die Kontaktzone.
        descent_target = safe_geomean([
            abs(yang_y_inverted) + EPSILON,
            yang_gate_pressure + EPSILON,
            center_contact_seed + EPSILON,
        ])
        s.x_mid_descent = lerp(s.x_mid_descent, descent_target, CENTER_RATE)

        # Vor dem Kontakt: X_mid pendelt eng.
        s.phase = (s.phase + CENTER_RATE * (0.6 + 0.4 * s.x_mid_descent)) % 1.0
        tight_pendulum = EPSILON * signed_wave(s.phase)
        pre_contact_x_mid = tight_pendulum

        # Begegnungsmoment: X_mid wird nicht Y-äquivalent, sondern voll X.
        contact = score_close(pre_contact_x_mid, yang_y_inverted, 1.0)
        s.x_mid_cross_activation = safe_geomean([
            contact + EPSILON,
            s.x_mid_descent + EPSILON,
            yang_gate_pressure + EPSILON,
        ])
        s.x_mid_functional_x = clamp01(s.x_mid_cross_activation * (0.75 + 0.25 * reflection_feedback))

        # Im Kontakt antwortet X_mid als X: es schneidet / kreuzt, nicht kopiert.
        x_mid_target = clamp11(pre_contact_x_mid + s.x_mid_functional_x * math.copysign(PHI, -yang_y_inverted if abs(yang_y_inverted) > EPS else 1.0))
        s.x_mid = lerp(s.x_mid, x_mid_target, CENTER_RATE)

        # Äußere Yin-X bereiten den Kreuzschlag vor.
        outer_span = clamp11(PHI + (1.0 - PHI) * s.x_mid_functional_x)
        s.x_left = lerp(s.x_left, -outer_span, EDGE_RATE)
        s.x_right = lerp(s.x_right, outer_span, EDGE_RATE)

        s.core_pressure = safe_geomean([
            s.x_mid_descent + EPSILON,
            s.x_mid_functional_x + EPSILON,
            abs(s.x_right - s.x_left) / 2.0 + EPSILON,
        ])

        s.x_left_pos = denorm_gate(s.x_left * 0.999, YIN_LEFT_BOUND, YIN_RIGHT_BOUND)
        # X_mid-Position: Projektion der Senkung in Richtung 4|5, ohne die Core-Identität zu löschen.
        s.x_mid_pos = lerp(YIN_CENTER, YANG_CENTER, s.x_mid_descent)
        s.x_right_pos = denorm_gate(s.x_right * 0.999, YIN_LEFT_BOUND, YIN_RIGHT_BOUND)

        s.score = safe_geomean([
            s.core_pressure + EPSILON,
            s.x_mid_functional_x + EPSILON,
            phi_ratio_score(abs(s.x_right - s.x_left), abs(s.x_mid) + EPSILON) + EPSILON,
            1.0 - abs((s.x_left + s.x_right) / 2.0) + EPSILON,
        ])

        return {"state": asdict(s)}


