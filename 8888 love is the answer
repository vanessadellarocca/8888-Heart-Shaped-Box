# 7) MEMBRANEN 12|1 UND 8|9 — pulsierende Ventile, keine Mauern
# ============================================================

@dataclass
class MembranePairState:
    opening_12_1: float = 0.0
    opening_8_9: float = 0.0
    pulse: float = 0.0
    release: float = 0.0
    inversion_risk_12_1: float = 0.0
    inversion_risk_8_9: float = 0.0
    membrane_score: float = 0.0
    permeability_moment: float = 0.0
    pressure: float = 0.0
    micro_flicker: float = EPSILON


@dataclass
class MembranePair12_1_8_9:
    state: MembranePairState = field(default_factory=MembranePairState)
    phase: float = 0.0

    def step(
        self,
        center_release: float,
        edge_braid: float,
        inward_pull: float,
        outward_pressure: float,
        lower_heart_return: float,
        upper_heart_return: float,
        reflection_feedback: float = 0.0,
    ) -> Dict[str, Any]:
        s = self.state
        self.phase = (self.phase + MEMBRANE_RATE * (0.5 + 0.5 * center_release)) % 1.0

        # Epsilon-Flimmern: nie komplett dicht, nie naiv offen.
        s.micro_flicker = EPSILON * (1.0 + 0.5 * signed_wave(self.phase))

        # Öffnung nur, wenn Ränder halten.
        protected_release = center_release * edge_braid * inward_pull
        s.pulse = lerp(s.pulse, protected_release, MEMBRANE_RATE)

        # 12|1: Geburts-/Quellmembran, durch oberen Kontaktbogen leichter moduliert.
        target_12_1 = clamp01(s.pulse * (0.65 + 0.35 * upper_heart_return) + s.micro_flicker)
        # 8|9: Transformationsmembran, durch unteren Tiefenbogen stärker belastet.
        target_8_9 = clamp01(s.pulse * (0.65 + 0.35 * lower_heart_return) + s.micro_flicker)

        s.opening_12_1 = lerp(s.opening_12_1, target_12_1, MEMBRANE_RATE)
        s.opening_8_9 = lerp(s.opening_8_9, target_8_9, MEMBRANE_RATE)

        s.inversion_risk_12_1 = clamp01(s.opening_12_1 * outward_pressure * (1.0 - edge_braid))
        s.inversion_risk_8_9 = clamp01(s.opening_8_9 * outward_pressure * (1.0 - edge_braid))

        s.release = safe_geomean([
            s.opening_12_1 + EPSILON,
            s.opening_8_9 + EPSILON,
            edge_braid + EPSILON,
            inward_pull + EPSILON,
        ])
        s.permeability_moment = clamp01(s.release * (1.0 - max(s.inversion_risk_12_1, s.inversion_risk_8_9)))
        s.pressure = clamp01(outward_pressure * (1.0 - s.release) + center_release * (1.0 - edge_braid))
        s.membrane_score = safe_geomean([
            s.permeability_moment + EPSILON,
            1.0 - s.inversion_risk_12_1 + EPSILON,
            1.0 - s.inversion_risk_8_9 + EPSILON,
            s.release + EPSILON,
        ])

        return {"state": asdict(s)}


