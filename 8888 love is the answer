@dataclass
class LightResonanceState:
    resonant_y_light: float = 0.0
    resonant_x_light: float = 0.0
    light_coherence: float = 0.0
    identity_preservation: float = 1.0
    resonance_pressure: float = 0.0
    release_trace: float = 1.0
    light_score: float = 0.0
    phase: float = 0.0


@dataclass
class LightResonanceLayer:
    state: LightResonanceState = field(default_factory=LightResonanceState)

    def step(
        self,
        core_pair: CorePairState,
        dao: DaoBreathState,
        membrane: MembranePairState,
        reflection_feedback: float = 0.0,
    ) -> Dict[str, Any]:
        s = self.state
        s.phase = (s.phase + LIGHT_RATE * (0.5 + 0.5 * core_pair.core_pair_score)) % 1.0

        # Licht-Echo: nicht kopieren, sondern innerlich resonanzfähig machen.
        y_light_target = clamp11(core_pair.center_contact * signed_wave(s.phase))
        x_light_target = clamp11(core_pair.edge_braid * signed_wave(s.phase + 0.5))

        s.resonant_y_light = lerp(s.resonant_y_light, y_light_target, LIGHT_RATE)
        s.resonant_x_light = lerp(s.resonant_x_light, x_light_target, LIGHT_RATE)

        s.resonance_pressure = clamp01(core_pair.center_cross_event * (1.0 - membrane.release))
        s.identity_preservation = clamp01(1.0 - s.resonance_pressure * (1.0 - dao.dao_score) * 0.5)
        s.release_trace = clamp01(1.0 - max(membrane.inversion_risk_12_1, membrane.inversion_risk_8_9))

        s.light_coherence = safe_geomean([
            s.identity_preservation + EPSILON,
            score_close(s.resonant_y_light, -s.resonant_x_light, 2.0) + EPSILON,
            core_pair.phase_coherence + EPSILON,
            dao.dao_score + EPSILON,
            membrane.membrane_score + EPSILON,
        ])
        s.light_score = clamp01(s.light_coherence * (0.85 + 0.15 * reflection_feedback))

        return {"state": asdict(s)}


