        self.phase = phase_step(
            self.phase,
            dao_phase,
            COUPLING_RATE * (0.52 + 0.26 * dao_score + 0.10 * reflection_score + 0.12 * coherence_score) * (0.70 + 0.30 * damping),
        )

        light_phase_bias = float(light_mod.get("phase_bias", 0.0))
        coherence_phase_bias = float(coherence_mod.get("phase_bias", coherence_state.get("phase_bias", 0.0)))
        effective_phase = (self.phase + 0.05 * light_phase_bias + 0.03 * coherence_phase_bias) % 1.0
