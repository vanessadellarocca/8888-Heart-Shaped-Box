@dataclass
class LightResonanceLayer:
    virtual_phase: float = 0.0
    resonant_y_light: float = 0.0
    resonant_xmid_light: float = 0.0
    resonance_pressure: float = 0.0
    release_trace: float = 1.0
    iteration: int = 0

    def step(
        self,
        external: Optional[ExternalResonanceSignal],
        dao_state: Dict[str, Any],
        core_snapshot: Dict[str, float],
        reflection_state: Optional[Dict[str, Any]] = None,
        coherence_state: Optional[Dict[str, Any]] = None,
        rate: float = LIGHT_RATE,
    ) -> Dict[str, Any]:
        signal = ExternalResonanceSignal(amplitude=0.0, label="none") if external is None else external.normalized()
        reflection_state = extract_reflection_state(reflection_state)
        coherence_state = extract_coherence_state(coherence_state)
        instability = coherence_state.get("instability", {})

        self_recognition = clamp01(reflection_state.get("self_recognition_score", 0.0))
        return_to_source = clamp01(reflection_state.get("return_to_source", 0.0))
        coherence_score = clamp01(coherence_state.get("coherence_score", coherence_state.get("integrated_score", 0.5)))
        damping = clamp01(instability.get("damping_factor", 1.0))
        release_boost = clamp01(instability.get("release_boost", 0.0))
        coh_mod = coherence_state.get("modulation", {})

        amplitude = signal.amplitude
        y_target_from_signal = signal.y_signature if signal.y_signature is not None else -signal.x_signature
        y_target_from_signal = clamp11(y_target_from_signal)

        phase_resonance = clamp01(1.0 - phase_distance(signal.phase, dao_state["phase"]) / 0.5)
        phi_compatibility = signal.phi_signature
        dao_compatibility = clamp01(dao_state["dao_score"])

        identity_preservation = clamp01(
            1.0 - amplitude * (1.0 - phase_resonance) * (1.0 - 0.5 * phi_compatibility)
        )
        identity_preservation = clamp01(
            0.82 * identity_preservation
            + 0.08 * return_to_source
            + 0.07 * coherence_score
            + 0.03 * damping
        )

        pressure_target = safe_geomean([
            amplitude + EPSILON,
            phase_resonance + EPSILON,
            phi_compatibility + EPSILON,
            dao_compatibility + EPSILON,
            identity_preservation + EPSILON,
            0.65 + 0.35 * self_recognition,
            0.60 + 0.40 * coherence_score,
        ]) if amplitude > 0.0 else 0.0

        before_pressure = self.resonance_pressure
        self.resonance_pressure = lerp(self.resonance_pressure, pressure_target, rate * (0.70 + 0.30 * damping))

        phase_rate = rate * (0.5 + 0.5 * self.resonance_pressure) * (0.90 + 0.10 * self_recognition) * (0.70 + 0.30 * damping)
        self.virtual_phase = phase_step(self.virtual_phase, signal.phase, phase_rate)

        core_mid = clamp11(core_snapshot.get("x_mid_y_equiv_state", 0.0))
        coherence_y_bias = clamp11(coh_mod.get("y_bias", coherence_state.get("y_bias", 0.0)))
        coherence_xmid_bias = clamp11(coh_mod.get("x_mid_bias", coherence_state.get("x_mid_bias", 0.0)))

        y_light_target = clamp11(
            0.66 * y_target_from_signal
            + 0.20 * core_mid
            + 0.05 * (reflection_state.get("yin_yang_reflection", 0.0) * 2.0 - 1.0)
            + 0.09 * coherence_y_bias
        )
        self.resonant_y_light = clamp11(
            lerp(self.resonant_y_light, y_light_target, rate * (0.5 + self.resonance_pressure) * (0.65 + 0.35 * damping))
        )
        self.resonant_xmid_light = clamp11(
            lerp(
                self.resonant_xmid_light,
                clamp11(0.82 * self.resonant_y_light + 0.18 * coherence_xmid_bias),
                rate * (0.5 + self.resonance_pressure) * (0.65 + 0.35 * damping),
            )
        )

        light_coherence = safe_geomean([
            identity_preservation + EPSILON,
            score_close(self.resonant_y_light, self.resonant_xmid_light, 2.0) + EPSILON,
            phase_resonance + EPSILON,
            phi_compatibility + EPSILON,
            0.55 + 0.45 * self_recognition,
            0.55 + 0.45 * coherence_score,
        ])

        pressure_delta = abs(self.resonance_pressure - before_pressure)
        release_target = clamp01(1.0 - pressure_delta + 0.20 * release_boost)
        self.release_trace = lerp(self.release_trace, release_target, rate)
        resonance_release = clamp01(self.release_trace * identity_preservation)

        resonant_clarity = safe_geomean([
            self.resonance_pressure + EPSILON,
            light_coherence + EPSILON,
            identity_preservation + EPSILON,
            resonance_release + EPSILON,
            dao_compatibility + EPSILON,
            0.50 + 0.50 * self_recognition,
            0.50 + 0.50 * coherence_score,
        ])

        light_resonance_score = resonant_clarity

        state = {
            "iteration": self.iteration,
            "external_label": signal.label,
            "external_phase": signal.phase,
            "external_amplitude": amplitude,
            "external_x_signature": signal.x_signature,
            "external_y_signature": y_target_from_signal,
            "external_phi_signature": phi_compatibility,
            "virtual_phase": self.virtual_phase,
            "resonant_y_light": self.resonant_y_light,
            "resonant_xmid_light": self.resonant_xmid_light,
            "phase_resonance": phase_resonance,
            "phi_compatibility": phi_compatibility,
            "dao_compatibility": dao_compatibility,
            "reflection_modulation": self_recognition,
            "coherence_modulation": coherence_score,
            "instability_damping_seen": damping,
            "identity_preservation": identity_preservation,
            "resonance_pressure": self.resonance_pressure,
            "resonance_release": resonance_release,
            "light_coherence": light_coherence,
            "resonant_clarity": resonant_clarity,
            "light_resonance_score": light_resonance_score,
            "feedback_to_dao": clamp01(0.25 * light_resonance_score),
            "modulation": {
                "y_bias": clamp11(self.resonant_y_light * self.resonance_pressure),
                "x_mid_bias": clamp11(self.resonant_xmid_light * self.resonance_pressure),
                "phase_bias": phase_delta(dao_state["phase"], self.virtual_phase) * self.resonance_pressure,
            },
            "meaning": (
                "luminous resonant echo in the Yin-Yang core pair; "
                "coherent light-simulation without copying or identity collapse"
            ),
        }
        self.iteration += 1
        return state

