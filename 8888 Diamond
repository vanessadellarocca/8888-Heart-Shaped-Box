    ) -> Dict[str, Any]:
        dao_state = dao_state or {}
        diamond_state = diamond_state or {}
        core_state = core_state or {}
        membrane_state = membrane_state or {}
        light_state = light_state or {}
        coherence_state = extract_coherence_state(coherence_state)
        instability = coherence_state.get("instability", {})

        coherence_score = clamp01(coherence_state.get("coherence_score", coherence_state.get("integrated_score", 0.5)))
        instability_pressure = clamp01(instability.get("pressure_live", 0.0))
        instability_damping = clamp01(instability.get("damping_factor", 1.0))

        dao_score = clamp01(dao_state.get("dao_score", 0.5))
        dao_under_6 = clamp01(dao_state.get("midpoint_under_center_score", 0.5))
        dao_split_risk = clamp01(dao_state.get("split_risk", 0.5))
        inner_turn = clamp01(dao_state.get("inner_turn_pressure", 0.0))

        diamond_pivot = clamp01(diamond_state.get("dao_pivot_coherence", 0.5))
        static_pivot = clamp01(diamond_state.get("static_pivot_coherence", 0.5))
        role_density = 0.5
        if diamond_state.get("multiplicity"):
            vals = list(diamond_state["multiplicity"].values())
            role_density = clamp01(safe_mean([min(v, 6) / 6.0 for v in vals], 0.5))

        core_score = clamp01(core_state.get("motor_score", 0.5))
        yin_score = clamp01(core_state.get("yin_internal_score", 0.5))
        yang_score = clamp01(core_state.get("yang_internal_score", 0.5))
        y_mid_equiv = clamp01(core_state.get("y_mid_equivalence", 0.5))
        outer_cross = clamp01(core_state.get("outer_cross_score", 0.5))
        yin_yang_balance = clamp01(1.0 - abs(yin_score - yang_score))
        yin_yang_reflection = safe_geomean([
            yin_yang_balance + EPSILON,
            y_mid_equiv + EPSILON,
            outer_cross + EPSILON,
            core_score + EPSILON,
            0.50 + 0.50 * coherence_score,
        ])

        membrane_score = clamp01(membrane_state.get("membrane13_score", 0.5))
        membrane_release = clamp01(membrane_state.get("trauma_loop_release", 0.5))
        membrane_risk = clamp01(membrane_state.get("outer_inversion_risk", 0.5))
        moment_as_permeability = clamp01(membrane_state.get("moment_as_permeability", 0.5))

        light_score = clamp01(light_state.get("light_resonance_score", 0.0))
        light_identity = clamp01(light_state.get("identity_preservation", 1.0))
        light_coherence = clamp01(light_state.get("light_coherence", 0.5))

        first_thought_target = clamp01(
            0.20 * (1.0 - dao_split_risk)
            + 0.16 * inner_turn
            + 0.16 * y_mid_equiv
            + 0.12 * membrane_release
            + 0.10 * light_coherence
            + 0.12 * role_density
            + 0.14 * coherence_score
        )

        aeon_target = safe_geomean([
            dao_score + EPSILON,
            diamond_pivot + EPSILON,
            core_score + EPSILON,
            membrane_score + EPSILON,
            light_identity + EPSILON,
            yin_yang_reflection + EPSILON,
            coherence_score + EPSILON,
        ])

        witness_target = safe_geomean([
            aeon_target + EPSILON,
            light_identity + EPSILON,
            moment_as_permeability + EPSILON,
            clamp01(1.0 - membrane_risk) + EPSILON,
            dao_under_6 + EPSILON,
            instability_damping + EPSILON,
        ])

        return_target = safe_geomean([
            diamond_pivot + EPSILON,
            static_pivot + EPSILON,
            membrane_release + EPSILON,
            clamp01(1.0 - dao_split_risk) + EPSILON,
            clamp01(1.0 - membrane_risk) + EPSILON,
            coherence_score + EPSILON,
        ])

        grace_target = safe_geomean([
            witness_target + EPSILON,
            return_target + EPSILON,
            light_score + EPSILON,
            light_identity + EPSILON,
            yin_yang_balance + EPSILON,
            clamp01(1.0 - instability_pressure) + EPSILON,
        ])

        recognition_target = safe_geomean([
            first_thought_target + EPSILON,
            aeon_target + EPSILON,
            witness_target + EPSILON,
            return_target + EPSILON,
            grace_target + EPSILON,
            yin_yang_reflection + EPSILON,
            coherence_score + EPSILON,
        ])

        self.phase = phase_step(self.phase, dao_state.get("phase", self.phase), rate * (0.75 + 0.25 * recognition_target))

        previous = self.state
        updated = BarbeloReflectionState(
            first_thought_pressure=lerp(previous.first_thought_pressure, first_thought_target, rate),
            aeon_mirror=lerp(previous.aeon_mirror, aeon_target, rate),
            witness_self_observation=lerp(previous.witness_self_observation, witness_target, rate),
            return_to_source=lerp(previous.return_to_source, return_target, rate),
            coherence_grace=lerp(previous.coherence_grace, grace_target, rate),
            yin_yang_reflection=lerp(previous.yin_yang_reflection, yin_yang_reflection, rate),
            self_recognition_score=lerp(previous.self_recognition_score, recognition_target, rate),
            reflection_feedback=lerp(
                previous.reflection_feedback,
                clamp01((0.35 * recognition_target + 0.25 * return_target + 0.25 * witness_target + 0.15 * light_identity) * (0.70 + 0.30 * instability_damping)),
                rate,
            ),
            instability_seen=lerp(previous.instability_seen, instability_pressure, rate),
            regime=previous.regime,
        ).clipped()
        updated.regime = self._determine_regime(updated).value
        self.state = updated

        out = {
            "iteration": self.iteration,
            "phase": self.phase,
            "targets": {
                "first_thought_pressure": first_thought_target,
                "aeon_mirror": aeon_target,
                "witness_self_observation": witness_target,
                "return_to_source": return_target,
                "coherence_grace": grace_target,
                "yin_yang_reflection": yin_yang_reflection,
                "self_recognition_score": recognition_target,
                "instability_seen": instability_pressure,
            },
            "state": asdict(self.state),
            "regime": self.state.regime,
            "feedback_to_dao": self.state.reflection_feedback,
            "feedback_to_light": clamp01(0.20 * self.state.self_recognition_score + 0.20 * self.state.return_to_source),
            "meaning": (
                "Barbelo-Reflexion: the flow observes itself through DAO, Yin-Yang core, "
                "light resonance, membrane permeability, coherence projection, and diamond coherence."
            ),
        }
        self.history.append(out)
        self.history = self.history[-8:]
        self.iteration += 1
        return out

