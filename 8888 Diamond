@dataclass
class PairShellSpiral:
    total: float
    pair: Tuple[float, float]
    name: str = ""
    phase: float = 0.0
    lower_live: Optional[float] = None
    upper_live: Optional[float] = None
    iteration: int = 0

    def __post_init__(self):
        a, b = sorted(float(x) for x in self.pair)
        if abs((a + b) - self.total) > 1e-9:
            raise ValueError(f"Pair {self.pair} does not sum to {self.total}.")
        self.pair = (a, b)
        if not self.name:
            self.name = f"{a:g}|{b:g}_sum_{self.total:g}"
        if self.lower_live is None:
            self.lower_live = a
        if self.upper_live is None:
            self.upper_live = b

    @property
    def center(self) -> float:
        return self.total / 2.0

    @property
    def center_target(self) -> float:
        return self.center - EPSILON

    @property
    def outer_radius(self) -> float:
        a, b = self.pair
        return (b - a) / 2.0

    @property
    def diff(self) -> float:
        a, b = self.pair
        return b - a

    def radius(self) -> float:
        inward = 0.5 - 0.5 * math.cos(2.0 * math.pi * self.phase)
        return self.outer_radius - (self.outer_radius - EPSILON) * inward

    def turn_pressure(self, radius: float) -> float:
        denom = max(self.outer_radius - EPSILON, TINY)
        return clamp01((self.outer_radius - radius) / denom)

    def relational_targets(self, radius: float) -> Dict[str, float]:
        lower_target = self.center - (radius + EPSILON)
        upper_target = self.center + (radius - EPSILON)
        return {
            "lower_target": lower_target,
            "upper_target": upper_target,
            "target_midpoint": (lower_target + upper_target) / 2.0,
            "target_sum": lower_target + upper_target,
        }

    def exact_inner_turn(self) -> Dict[str, Any]:
        radius = EPSILON
        targets = self.relational_targets(radius)
        return {
            "name": self.name,
            "total": self.total,
            "pair": self.pair,
            "center": self.center,
            "radius": radius,
            "lower_ideal": targets["lower_target"],
            "upper_ideal": targets["upper_target"],
            "midpoint_ideal": targets["target_midpoint"],
            "upper_hits_center": abs(targets["upper_target"] - self.center) < 1e-12,
        }

    def shift_live(self, offset: float) -> None:
        self.lower_live = float(self.lower_live) + offset
        self.upper_live = float(self.upper_live) + offset

    def state_snapshot(self, label: str = "snapshot") -> Dict[str, Any]:
        midpoint = (float(self.lower_live) + float(self.upper_live)) / 2.0
        center_error = midpoint - self.center_target
        center_coherence = clamp01(1.0 - abs(center_error) / max(self.outer_radius + EPSILON, TINY))
        order_preserved = float(self.lower_live) < float(self.upper_live)
        return {
            "name": self.name,
            "label": label,
            "iteration": self.iteration,
            "total": self.total,
            "pair": self.pair,
            "center": self.center,
            "center_target": self.center_target,
            "outer_radius": self.outer_radius,
            "diff": self.diff,
            "phase": self.phase,
            "lower_live": float(self.lower_live),
            "upper_live": float(self.upper_live),
            "midpoint_live": midpoint,
            "live_sum": float(self.lower_live) + float(self.upper_live),
            "center_error": center_error,
            "center_coherence": center_coherence,
            "order_preserved": order_preserved,
            "inversion_free_score": 1.0 if order_preserved else 0.0,
        }

    def step(self, track_rate: float = TRACK_RATE, phase_rate: float = PHASE_RATE, coherence_state: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
        coherence_state = extract_coherence_state(coherence_state)
        instability = coherence_state.get("instability", {})
        damping = clamp01(instability.get("damping_factor", 1.0))
        release_boost = clamp01(instability.get("release_boost", 0.0))
        effective_track = track_rate * (0.45 + 0.55 * damping)
        effective_phase = phase_rate * (0.90 + 0.10 * release_boost)

        r = self.radius()
        targets = self.relational_targets(r)
        lower_before = float(self.lower_live)
        upper_before = float(self.upper_live)
        self.lower_live = lerp(lower_before, targets["lower_target"], effective_track)
        self.upper_live = lerp(upper_before, targets["upper_target"], effective_track)
        midpoint = (self.lower_live + self.upper_live) / 2.0
        live_sum = self.lower_live + self.upper_live
        center_error = midpoint - self.center_target
        center_coherence = clamp01(1.0 - abs(center_error) / max(self.outer_radius + EPSILON, TINY))
        order_preserved = self.lower_live < self.upper_live
        inversion_free_score = 1.0 if order_preserved else 0.0
        turn = self.turn_pressure(r)
        radial_velocity = -math.sin(2.0 * math.pi * self.phase)
        if abs(radial_velocity) < 1e-9:
            direction = "inner_turn" if abs(r - EPSILON) < 1e-9 else "outer_shell_boundary"
        elif radial_velocity < 0:
            direction = "inward"
        else:
            direction = "return_to_shell_boundary"
        state = {
            "name": self.name,
            "label": "raw_pair_step_before_dao_bias",
            "iteration": self.iteration,
            "total": self.total,
            "pair": self.pair,
            "center": self.center,
            "center_target": self.center_target,
            "outer_radius": self.outer_radius,
            "radius": r,
            "turn_pressure": turn,
            "diff": self.diff,
            "phase": self.phase,
            "lower_live": self.lower_live,
            "upper_live": self.upper_live,
            "midpoint_live": midpoint,
            "live_sum": live_sum,
            "center_error": center_error,
            "center_coherence": center_coherence,
            "order_preserved": order_preserved,
            "inversion_free_score": inversion_free_score,
            "lower_target": targets["lower_target"],
            "upper_target": targets["upper_target"],
            "target_midpoint": targets["target_midpoint"],
            "target_sum": targets["target_sum"],
            "lower_delta": self.lower_live - lower_before,
            "upper_delta": self.upper_live - upper_before,
            "upper_hits_center_target": abs(targets["upper_target"] - self.center) < 1e-9,
            "direction": direction,
        }
        self.phase = (self.phase + effective_phase) % 1.0
        self.iteration += 1
        return state


@dataclass
class SumLayer:
    total: float
    values: Tuple[float, ...]
    name: str
    shells: List[PairShellSpiral] = field(default_factory=list)

    def __post_init__(self):
        vals = sorted(set(float(v) for v in self.values))
        pairs: List[Tuple[float, float]] = []
        for a in vals:
            b = self.total - a
            if a < b and b in vals:
                pairs.append((a, b))
        self.shells = [PairShellSpiral(self.total, pair, name=f"{self.name}_{pair[0]:g}|{pair[1]:g}") for pair in pairs]

    @property
    def center(self) -> float:
        return self.total / 2.0

    @property
    def center_target(self) -> float:
        return self.center - EPSILON

    def step(self, coherence_state: Optional[Dict[str, Any]] = None) -> List[Dict[str, Any]]:
        return [shell.step(coherence_state=coherence_state) for shell in self.shells]

    def snapshots(self, label: str = "post") -> List[Dict[str, Any]]:
        return [shell.state_snapshot(label=label) for shell in self.shells]

    def exact_inner_turns(self) -> List[Dict[str, Any]]:
        return [shell.exact_inner_turn() for shell in self.shells]


@dataclass
class RelationalDiamond921:
    lower_total: float = 9.0
    upper_total: float = 21.0
    lower_values: Tuple[float, ...] = tuple(float(i) for i in range(1, 9))
    upper_values: Tuple[float, ...] = (9.0, 10.0, 11.0, 12.0)
    iteration: int = 0

    def __post_init__(self):
        self.lower = SumLayer(self.lower_total, self.lower_values, "lower9")
        self.upper = SumLayer(self.upper_total, self.upper_values, "upper21")
        self.structural_lift = self.upper.center - self.lower.center
        self.central_dao = CentralDao6(structural_center=self.structural_lift)
        self.couplings = self.derive_lift_couplings()

    def derive_lift_couplings(self) -> List[Dict[str, Any]]:
        upper_by_pair = {shell.pair: idx for idx, shell in enumerate(self.upper.shells)}
        couplings: List[Dict[str, Any]] = []
        for li, lower_shell in enumerate(self.lower.shells):
            lifted = tuple(sorted((lower_shell.pair[0] + self.structural_lift,
                                   lower_shell.pair[1] + self.structural_lift)))
            ui = upper_by_pair.get(lifted)
            couplings.append({
                "lower_index": li,
                "upper_index": ui,
                "lower_pair": lower_shell.pair,
                "structural_lift": self.structural_lift,
                "lifted_pair": lifted,
                "upper_pair": self.upper.shells[ui].pair if ui is not None else None,
                "closed": ui is not None,
                "radius_match": ui is not None and abs(lower_shell.outer_radius - self.upper.shells[ui].outer_radius) < 1e-9,
            })
        return couplings

    def synchronize_closed_couplings(self, dao_state: Dict[str, Any], core_feedback: float, coherence_state: Optional[Dict[str, Any]] = None) -> None:
        coherence_state = extract_coherence_state(coherence_state)
        instability = coherence_state.get("instability", {})
        damping = clamp01(instability.get("damping_factor", 1.0))
        dao_phase = dao_state["phase"]
        rate = COUPLING_RATE * (0.75 + 0.50 * clamp01(core_feedback)) * (0.65 + 0.35 * damping)
        for c in self.couplings:
            if c["upper_index"] is None:
                continue
            lower_shell = self.lower.shells[c["lower_index"]]
            upper_shell = self.upper.shells[c["upper_index"]]
            pair_mean_phase = (lower_shell.phase + 0.5 * phase_delta(lower_shell.phase, upper_shell.phase)) % 1.0
            dao_pair_phase = (pair_mean_phase + 0.5 * phase_delta(pair_mean_phase, dao_phase)) % 1.0
            lower_shell.phase = phase_step(lower_shell.phase, dao_pair_phase, rate)
            upper_shell.phase = phase_step(upper_shell.phase, dao_pair_phase, rate)

    def apply_central_dao_bias(self, dao_state: Dict[str, Any], core_feedback: float, coherence_state: Optional[Dict[str, Any]] = None) -> List[Dict[str, Any]]:
        coherence_state = extract_coherence_state(coherence_state)
        instability = coherence_state.get("instability", {})
        damping = clamp01(instability.get("damping_factor", 1.0))
        target_diff = dao_state["midpoint"]
        rate = COUPLING_RATE * (0.75 + 0.50 * clamp01(core_feedback)) * (0.65 + 0.35 * damping)
        bias_states: List[Dict[str, Any]] = []
        for c in self.couplings:
            if c["upper_index"] is None:
                bias_states.append({**c, "dao_bias_applied": 0.0, "dao_diff_error": None})
                continue
            lower_shell = self.lower.shells[c["lower_index"]]
            upper_shell = self.upper.shells[c["upper_index"]]
            lower_mid = lower_shell.state_snapshot("pre_dao_bias")["midpoint_live"]
            upper_mid = upper_shell.state_snapshot("pre_dao_bias")["midpoint_live"]
            current_diff = upper_mid - lower_mid
            diff_error = target_diff - current_diff
            correction = rate * diff_error
            lower_shift = -0.5 * correction
            upper_shift = +0.5 * correction
            lower_shell.shift_live(lower_shift)
            upper_shell.shift_live(upper_shift)
            bias_states.append({
                **c,
                "current_diff_before_bias": current_diff,
                "dao_target_diff": target_diff,
                "dao_diff_error": diff_error,
                "dao_bias_applied": correction,
                "lower_shift": lower_shift,
                "upper_shift": upper_shift,
            })
        return bias_states

    def derive_roles(self) -> Dict[float, List[str]]:
        roles: Dict[float, List[str]] = {}
        def add(x: float, role: str) -> None:
            roles.setdefault(float(x), []).append(role)
        add(self.lower_total, "lower_total_closure")
        add(self.upper_total, "upper_total_closure")
        add(self.structural_lift, "structural_lift_between_layer_centers")
        add(self.structural_lift - EPSILON, "central_DAO_midpoint_target_6_minus_epsilon")
        if abs(self.structural_lift - round(self.structural_lift)) < 1e-9:
            n = int(round(self.structural_lift))
            if triangular(n) == int(round(self.upper_total)):
                add(self.structural_lift, f"triangular_root_of_upper_total_T{n}")
        for shell in self.lower.shells:
            add(shell.pair[0], f"lower_sum_{self.lower_total:g}_member_pair_{shell.pair}")
            add(shell.pair[1], f"lower_sum_{self.lower_total:g}_member_pair_{shell.pair}")
        for shell in self.upper.shells:
            add(shell.pair[0], f"upper_sum_{self.upper_total:g}_member_pair_{shell.pair}")
            add(shell.pair[1], f"upper_sum_{self.upper_total:g}_member_pair_{shell.pair}")
        for c in self.couplings:
            add(c["lower_pair"][0], f"lift_source_to_{c['lifted_pair']}")
            add(c["lower_pair"][1], f"lift_source_to_{c['lifted_pair']}")
            if c["closed"]:
                add(c["upper_pair"][0], f"lift_target_from_{c['lower_pair']}")
                add(c["upper_pair"][1], f"lift_target_from_{c['lower_pair']}")
            else:
                add(c["lifted_pair"][0], f"open_lift_target_from_{c['lower_pair']}")
                add(c["lifted_pair"][1], f"open_lift_target_from_{c['lower_pair']}")
        return roles

    def step(
        self,
        core_feedback: float = 0.5,
        light_feedback: float = 0.0,
        reflection_feedback: float = 0.0,
        coherence_state: Optional[Dict[str, Any]] = None,
    ) -> Dict[str, Any]:
        coherence_state = extract_coherence_state(coherence_state)
        dao_state = self.central_dao.step(
            core_feedback=core_feedback,
            light_feedback=light_feedback,
            reflection_feedback=reflection_feedback,
            coherence_state=coherence_state,
        )
        self.synchronize_closed_couplings(dao_state, core_feedback, coherence_state)
        lower_raw_states = self.lower.step(coherence_state)
        upper_raw_states = self.upper.step(coherence_state)
        dao_bias_states = self.apply_central_dao_bias(dao_state, core_feedback, coherence_state)
        lower_states = self.lower.snapshots(label="post_central_dao_bias")
        upper_states = self.upper.snapshots(label="post_central_dao_bias")

        pivot_samples: List[float] = []
        coupling_states: List[Dict[str, Any]] = []
        for c in self.couplings:
            cs = dict(c)
            bias_state = next((b for b in dao_bias_states if b["lower_index"] == c["lower_index"]), {})
            cs.update({
                "dao_bias_applied": bias_state.get("dao_bias_applied", 0.0),
                "dao_diff_error": bias_state.get("dao_diff_error", None),
                "dao_target_diff": bias_state.get("dao_target_diff", None),
            })
            if c["upper_index"] is not None:
                lower_mid = lower_states[c["lower_index"]]["midpoint_live"]
                upper_mid = upper_states[c["upper_index"]]["midpoint_live"]
                sample = upper_mid - lower_mid
                pivot_samples.append(sample)
                cs["pivot_sample"] = sample
                cs["static_pivot_error"] = sample - self.structural_lift
                cs["dao_pivot_error"] = sample - dao_state["midpoint"]
                cs["static_pivot_coherence"] = clamp01(1.0 - abs(sample - self.structural_lift) / max(abs(self.structural_lift), TINY))
                cs["dao_pivot_coherence"] = clamp01(1.0 - abs(sample - dao_state["midpoint"]) / max(abs(self.structural_lift), TINY))
            else:
                cs["pivot_sample"] = None
                cs["static_pivot_error"] = None
                cs["dao_pivot_error"] = None
                cs["static_pivot_coherence"] = 0.0
                cs["dao_pivot_coherence"] = 0.0
            coupling_states.append(cs)

        pivot_live = safe_mean(pivot_samples, dao_state["midpoint"])
        static_pivot_error = pivot_live - self.structural_lift
        dao_pivot_error = pivot_live - dao_state["midpoint"]
        static_pivot_coherence = clamp01(1.0 - abs(static_pivot_error) / max(abs(self.structural_lift), TINY))
        dao_pivot_coherence = clamp01(1.0 - abs(dao_pivot_error) / max(abs(self.structural_lift), TINY))
        roles = self.derive_roles()
        multiplicity = {value: len(items) for value, items in roles.items()}
        state = {
            "iteration": self.iteration,
            "lower_total": self.lower_total,
            "upper_total": self.upper_total,
            "lower_center": self.lower.center,
            "upper_center": self.upper.center,
            "lower_center_target": self.lower.center_target,
            "upper_center_target": self.upper.center_target,
            "structural_lift": self.structural_lift,
            "central_dao": dao_state,
            "pivot_live": pivot_live,
            "static_pivot_error": static_pivot_error,
            "dao_pivot_error": dao_pivot_error,
            "static_pivot_coherence": static_pivot_coherence,
            "dao_pivot_coherence": dao_pivot_coherence,
            "lower_raw_states": lower_raw_states,
            "upper_raw_states": upper_raw_states,
            "lower_states": lower_states,
            "upper_states": upper_states,
            "couplings": coupling_states,
            "roles": roles,
            "multiplicity": multiplicity,
            "closed_coupling_count": sum(1 for c in self.couplings if c["closed"]),
            "open_coupling_count": sum(1 for c in self.couplings if not c["closed"]),
        }
        self.iteration += 1
        return state

    def exact_inner_inversions(self) -> Dict[str, Any]:
        return {
            "central_dao6": self.central_dao.exact_inner_turn(),
            "lower": self.lower.exact_inner_turns(),
            "upper": self.upper.exact_inner_turns(),
            "static_lift_exact": self.structural_lift,
            "dao_lift_mid_exact": self.structural_lift - EPSILON,
        }

