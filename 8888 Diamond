@dataclass
class RingMembraneDiamondDaoCoreSystem:
    iteration: int = 0

    def __post_init__(self):
        self.ring = FunctionalRing12()
        self.diamond = RelationalDiamond921()
        self.core_motor = CoupledYinYangCoreMotor()
        self.light = LightResonanceLayer()
        self.reflection = BarbeloReflectionLayer()
        self.coherence = CoherenceProjectionLayer()
        self.membrane = BoundaryMembrane13()
        self.external_signal: Optional[ExternalResonanceSignal] = None

    def inject_external_signal(self, signal: Optional[ExternalResonanceSignal]) -> None:
        self.external_signal = signal

    def _get_shell_state(self, states: List[Dict[str, Any]], pair: Tuple[float, float]) -> Dict[str, Any]:
        target = tuple(sorted(float(x) for x in pair))
        for state in states:
            if tuple(state["pair"]) == target:
                return state
        raise KeyError(f"Shell state for pair {pair} not found.")

    def step(self) -> Dict[str, Any]:
        previous_coherence_state = self.coherence.current_state()
        previous_reflection_feedback = clamp01(self.reflection.state.reflection_feedback)
        previous_light_feedback = clamp01(self.light.resonance_pressure * 0.25)

        # 1) Diamond und DAO laufen mit verzögerter Kohärenzrückkopplung.
        diamond_state = self.diamond.step(
            core_feedback=clamp01(0.70 * self.core_motor.last_feedback + 0.30 * previous_coherence_state.get("core_feedback", 0.5)),
            light_feedback=clamp01(0.70 * previous_light_feedback + 0.30 * previous_coherence_state.get("light_feedback", 0.0)),
            reflection_feedback=clamp01(0.70 * previous_reflection_feedback + 0.30 * previous_coherence_state.get("reflection_feedback", 0.0)),
            coherence_state=previous_coherence_state,
        )
        central_dao_state = diamond_state["central_dao"]

        # 2) Vorreflexion: Selbstsicht mit altem Kohärenzzustand.
        pre_reflection = self.reflection.step(
            dao_state=central_dao_state,
            diamond_state=diamond_state,
            core_state={},
            membrane_state={},
            light_state={},
            coherence_state=previous_coherence_state,
        )
        pre_reflection_state = pre_reflection["state"]

        # 3) Lichtresonanz: Echo ohne Kopie, moduliert durch Reflexion und Kohärenz.
        light_state = self.light.step(
            external=self.external_signal,
            dao_state=central_dao_state,
            core_snapshot=self.core_motor.yin_feedback_snapshot(),
            reflection_state=pre_reflection_state,
            coherence_state=previous_coherence_state,
        )

        # 4) Yin-Yang-Core-Paar: echte Kreuzrückkopplung + Kohärenzbus.
        core_state = self.core_motor.step(
            central_dao_state,
            diamond_state,
            light_state,
            pre_reflection_state,
