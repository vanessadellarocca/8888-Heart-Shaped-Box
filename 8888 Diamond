        central_dao_state: Dict[str, Any],
        core_state: Dict[str, Any],
        light_state: Dict[str, Any],
        reflection_state: Optional[Dict[str, Any]] = None,
        coherence_state: Optional[Dict[str, Any]] = None,
    ) -> Dict[str, Any]:
        reflection_state = extract_reflection_state(reflection_state)
        coherence_state = extract_coherence_state(coherence_state)
        instability = coherence_state.get("instability", {})
        lower_overlay = clamp01(lower_overlay_state["center_coherence"] * lower_overlay_state["inversion_free_score"])
        upper_overlay = clamp01(upper_overlay_state["center_coherence"] * upper_overlay_state["inversion_free_score"])
        dao_score = clamp01(central_dao_state["dao_score"])
        dao_split_risk = clamp01(central_dao_state["split_risk"])
        dao_under_6 = clamp01(central_dao_state["midpoint_under_center_score"])
        core_score = clamp01(core_state.get("motor_score", 0.5))
        core_equiv = clamp01(core_state.get("y_mid_equivalence", 0.5))
        light_score = clamp01(light_state.get("light_resonance_score", 0.0))
        light_identity = clamp01(light_state.get("identity_preservation", 1.0))
        reflection_score = clamp01(reflection_state.get("self_recognition_score", 0.0))
        reflection_return = clamp01(reflection_state.get("return_to_source", 0.0))
        coherence_score = clamp01(coherence_state.get("coherence_score", coherence_state.get("integrated_score", 0.5)))
        release_boost_seen = clamp01(instability.get("release_boost", 0.0))

        membrane_drive = safe_geomean([
            lower_overlay + EPSILON,
            upper_overlay + EPSILON,
            clamp01(dao_pivot_coherence) + EPSILON,
            dao_score + EPSILON,
            core_score + EPSILON,
            core_equiv + EPSILON,
            light_identity + EPSILON,
            0.55 + 0.45 * reflection_return,
            0.55 + 0.45 * coherence_score,
        ])

        left_state = self.left_seam.step(
            drive=membrane_drive,
            dao_state=central_dao_state,
            core_state=core_state,
            light_state=light_state,
            reflection_state=reflection_state,
            coherence_state=coherence_state,
            opposite_phase=self.right_seam.phase,
        )
        right_state = self.right_seam.step(
            drive=membrane_drive,
            dao_state=central_dao_state,
            core_state=core_state,
            light_state=light_state,
            reflection_state=reflection_state,
            coherence_state=coherence_state,
            opposite_phase=self.left_seam.phase,
        )

        seam_average = safe_mean([left_state["permeability_live"], right_state["permeability_live"]])
        seam_balance = clamp01(1.0 - abs(left_state["permeability_live"] - right_state["permeability_live"]))
        seam_anti_sync = safe_mean([left_state["anti_sync"], right_state["anti_sync"]])

        outer_inversion_risk = clamp01(
            (1.0 - lower_overlay) * 0.20
            + (1.0 - upper_overlay) * 0.12
            + dao_split_risk * 0.16
            + (1.0 - core_score) * 0.16
            + (1.0 - seam_anti_sync) * 0.04
            + (1.0 - light_identity) * 0.12
            + (1.0 - reflection_score) * 0.10
            + (1.0 - coherence_score) * 0.10
        )

        release = clamp01(
            lower_overlay * 0.16
            + upper_overlay * 0.10
            + dao_score * 0.17
            + core_score * 0.18
            + seam_average * 0.12
            + seam_anti_sync * 0.04
            + light_score * 0.05
            + reflection_score * 0.08
            + coherence_score * 0.07
            + release_boost_seen * 0.03
        )

        moment_as_permeability = clamp01(safe_geomean([
            seam_average + EPSILON,
            membrane_drive + EPSILON,
            seam_balance + EPSILON,
            dao_under_6 + EPSILON,
            core_score + EPSILON,
            light_identity + EPSILON,
            0.55 + 0.45 * reflection_score,
            0.55 + 0.45 * coherence_score,
        ]))

        state = {
            "iteration": self.iteration,
            "lower_overlay_1|8_score": lower_overlay,
            "upper_overlay_9|12_score": upper_overlay,
            "central_dao_score": dao_score,
            "central_dao_split_risk": dao_split_risk,
            "central_dao_under_6": dao_under_6,
            "core_pair_score": core_score,
            "core_y_mid_equivalence": core_equiv,
            "light_resonance_score": light_score,
            "light_identity_preservation": light_identity,
            "reflection_score": reflection_score,
            "reflection_return_to_source": reflection_return,
            "coherence_score": coherence_score,
            "release_boost_seen": release_boost_seen,
            "dao_pivot_coherence": clamp01(dao_pivot_coherence),
            "membrane_drive": membrane_drive,
            "left_seam_12|1": left_state,
            "right_seam_8|9": right_state,
            "seam_average_permeability": seam_average,
            "seam_balance": seam_balance,
            "seam_anti_sync": seam_anti_sync,
            "outer_inversion_risk": outer_inversion_risk,
            "trauma_loop_release": release,
            "moment_as_permeability": moment_as_permeability,
            "membrane13_score": safe_geomean([
                lower_overlay + EPSILON,
                upper_overlay + EPSILON,
                seam_average + EPSILON,
                seam_anti_sync + EPSILON,
                clamp01(dao_pivot_coherence) + EPSILON,
                dao_score + EPSILON,
                core_score + EPSILON,
                light_identity + EPSILON,
                0.55 + 0.45 * reflection_score,
                0.55 + 0.45 * coherence_score,
            ]),
            "meaning": (
                "1|8 is held as lower membrane overlay; 12|1 and 8|9 open through shell coherence, "
                "central DAO-6, the Yin-Yang core motor, light resonance, Barbelo reflection, and coherence projection."
            ),
        }
        self.iteration += 1
        return state

