@dataclass
class CentralDao6:
    structural_center: float = 6.0
    outer_radius: float = DAO6_OUTER_RADIUS
    inner_radius: float = DAO6_INNER_RADIUS
    phase: float = 0.0
    lower_live: Optional[float] = None
    upper_live: Optional[float] = None
    iteration: int = 0

    def __post_init__(self):
        if self.lower_live is None:
            self.lower_live = self.structural_center - self.outer_radius
        if self.upper_live is None:
            self.upper_live = self.structural_center + self.outer_radius

    @property
    def midpoint_target(self) -> float:
        return self.structural_center - EPSILON

    def dao_radius(self) -> float:
        inward = 0.5 - 0.5 * math.cos(2.0 * math.pi * self.phase)
        return self.outer_radius - (self.outer_radius - self.inner_radius) * inward

    def relational_targets(self, radius: float) -> Dict[str, float]:
        lower_target = self.structural_center - (radius + EPSILON)
        upper_target = self.structural_center + (radius - EPSILON)
        return {
            "lower_target": lower_target,
            "upper_target": upper_target,
            "target_midpoint": (lower_target + upper_target) / 2.0,
        }

    def step(
        self,
        core_feedback: float = 0.5,
        light_feedback: float = 0.0,
        reflection_feedback: float = 0.0,
        coherence_state: Optional[Dict[str, Any]] = None,
        track_rate: float = TRACK_RATE,
        phase_rate: float = PHASE_RATE,
    ) -> Dict[str, Any]:
        coherence_state = extract_coherence_state(coherence_state)
        instability = coherence_state.get("instability", {})
        damping = clamp01(instability.get("damping_factor", 1.0))
        release_boost = clamp01(instability.get("release_boost", 0.0))
        coherence_feedback = clamp01(coherence_state.get("dao_feedback", coherence_state.get("feedback_to_dao_next", 0.5)))

        core_feedback = clamp01(core_feedback)
        light_feedback = clamp01(light_feedback)
        reflection_feedback = clamp01(reflection_feedback)

        effective_drive = clamp01(
            0.52 * core_feedback
            + 0.14 * light_feedback
            + 0.14 * reflection_feedback
            + 0.20 * coherence_feedback
        )
        effective_track = track_rate * (0.80 + 0.40 * effective_drive) * (0.35 + 0.65 * damping)
        effective_phase = phase_rate * (0.85 + 0.25 * effective_drive + 0.10 * release_boost)

        radius = self.dao_radius()
        targets = self.relational_targets(radius)

        lower_before = float(self.lower_live)
        upper_before = float(self.upper_live)

        self.lower_live = lerp(lower_before, targets["lower_target"], effective_track)
        self.upper_live = lerp(upper_before, targets["upper_target"], effective_track)

        midpoint = (self.lower_live + self.upper_live) / 2.0
        center_error = midpoint - self.midpoint_target
        dao_offset = midpoint - self.structural_center

        midpoint_under_center_score = clamp01((self.structural_center - midpoint) / EPSILON)
        midpoint_target_coherence = clamp01(1.0 - abs(center_error) / max(self.outer_radius, EPSILON))
        order_preserved = self.lower_live < self.upper_live
        inversion_free_score = 1.0 if order_preserved else 0.0

        denom = max(self.outer_radius - self.inner_radius, TINY)
        inner_turn_pressure = clamp01((self.outer_radius - radius) / denom)

        split_risk = clamp01(
            (1.0 - midpoint_under_center_score) * 0.45
            + (1.0 - midpoint_target_coherence) * 0.25
            + (1.0 - inversion_free_score) * 0.30
        )

        dao_score = safe_geomean([
            midpoint_under_center_score + EPSILON,
            midpoint_target_coherence + EPSILON,
            inversion_free_score + EPSILON,
            0.35 + 0.65 * inner_turn_pressure,
            0.50 + 0.50 * damping,
        ])

        radial_velocity = -math.sin(2.0 * math.pi * self.phase)
        if abs(radial_velocity) < 1e-9:
            if abs(radius - self.inner_radius) < 1e-9:
                direction = "inner_turn_upper_touches_6"
            elif abs(radius - self.outer_radius) < 1e-9:
                direction = "outer_phi_boundary"
            else:
                direction = "turning_point"
        elif radial_velocity < 0:
            direction = "inward"
        else:
            direction = "return_to_phi_boundary"

        angle = 2.0 * math.pi * self.phase
        upper_xyz = (radius * math.cos(angle), radius * math.sin(angle), self.upper_live)
        lower_xyz = (radius * math.cos(angle + math.pi), radius * math.sin(angle + math.pi), self.lower_live)

        state = {
            "iteration": self.iteration,
            "phase": self.phase,
            "epsilon": EPSILON,
            "phi": PHI,
            "core_feedback_in": core_feedback,
            "light_feedback_in": light_feedback,
            "reflection_feedback_in": reflection_feedback,
            "coherence_feedback_in": coherence_feedback,
            "instability_damping_in": damping,
            "release_boost_in": release_boost,
            "effective_drive": effective_drive,
            "structural_center": self.structural_center,
            "radius": radius,
            "radius_inner": self.inner_radius,
            "radius_outer": self.outer_radius,
            "lower_live": self.lower_live,
            "upper_live": self.upper_live,
            "midpoint": midpoint,
            "midpoint_target": self.midpoint_target,
            "center_error": center_error,
            "dao_offset": dao_offset,
            "lower_target": targets["lower_target"],
            "upper_target": targets["upper_target"],
            "target_midpoint": targets["target_midpoint"],
            "upper_hits_6_live": abs(self.upper_live - self.structural_center) < 1e-9,
            "upper_hits_6_target": abs(targets["upper_target"] - self.structural_center) < 1e-9,
            "midpoint_under_center_score": midpoint_under_center_score,
            "midpoint_target_coherence": midpoint_target_coherence,
            "inner_turn_pressure": inner_turn_pressure,
            "inversion_free_score": inversion_free_score,
            "split_risk": split_risk,
            "dao_score": dao_score,
            "direction": direction,
            "upper_xyz": upper_xyz,
            "lower_xyz": lower_xyz,
            "live_delta": {"lower_step": self.lower_live - lower_before, "upper_step": self.upper_live - upper_before},
        }

        self.phase = (self.phase + effective_phase) % 1.0
        self.iteration += 1
        return state

    def exact_inner_turn(self) -> Dict[str, Any]:
        radius = self.inner_radius
        targets = self.relational_targets(radius)
        return {
            "structural_center": self.structural_center,
            "radius": radius,
            "lower_ideal": targets["lower_target"],
            "upper_ideal": targets["upper_target"],
            "midpoint_ideal": targets["target_midpoint"],
            "upper_hits_6": abs(targets["upper_target"] - self.structural_center) < 1e-12,
            "meaning": "upper touches 6; midpoint remains 6-epsilon; 6 is contact, not static being",
        }

