@dataclass
class SeamBreather:
    name: str
    phase: float = 0.0
    permeability_live: float = EPSILON
    iteration: int = 0

    def step(
        self,
        drive: float,
        dao_state: Dict[str, Any],
        core_state: Dict[str, Any],
        light_state: Dict[str, Any],
        reflection_state: Optional[Dict[str, Any]] = None,
        coherence_state: Optional[Dict[str, Any]] = None,
        opposite_phase: Optional[float] = None,
        rate: float = SEAM_RATE,
    ) -> Dict[str, Any]:
        reflection_state = extract_reflection_state(reflection_state)
        coherence_state = extract_coherence_state(coherence_state)
        instability = coherence_state.get("instability", {})
        drive = clamp01(drive)
        local_wave = 0.5 + 0.5 * math.cos(2.0 * math.pi * self.phase)
        dao_wave = 0.5 + 0.5 * math.cos(2.0 * math.pi * dao_state["phase"])
        core_wave = 0.5 + 0.5 * clamp01(core_state.get("phase_anti_sync", 0.5))
        light_wave = 0.5 + 0.5 * clamp01(light_state.get("light_resonance_score", 0.0))
        reflection_wave = 0.5 + 0.5 * clamp01(reflection_state.get("self_recognition_score", 0.0))
        coherence_wave = 0.5 + 0.5 * clamp01(coherence_state.get("coherence_score", coherence_state.get("integrated_score", 0.5)))
        release_boost = clamp01(instability.get("release_boost", 0.0))
        damping = clamp01(instability.get("damping_factor", 1.0))
        wave = 0.27 * local_wave + 0.23 * dao_wave + 0.18 * core_wave + 0.10 * light_wave + 0.10 * reflection_wave + 0.12 * coherence_wave
        anti_sync = clamp01(phase_distance(self.phase, opposite_phase) / 0.5) if opposite_phase is not None else 1.0
        floor = EPSILON
        ceiling = 1.0 - EPSILON
        dao_drive = clamp01(dao_state["dao_score"])
        core_drive = clamp01(core_state.get("motor_score", 0.5))
        light_drive = clamp01(light_state.get("light_resonance_score", 0.0))
        reflection_drive = clamp01(reflection_state.get("self_recognition_score", 0.0))
        coherence_drive = clamp01(coherence_state.get("coherence_score", coherence_state.get("integrated_score", 0.5)))
        target = floor + (ceiling - floor) * drive * dao_drive * core_drive * (0.85 + 0.15 * light_drive) * (0.85 + 0.15 * reflection_drive) * (0.80 + 0.20 * coherence_drive) * (0.25 + 0.75 * wave) * (0.5 + 0.5 * anti_sync)
        target = clamp01(target + release_boost * 0.08)
        before = self.permeability_live
        self.permeability_live = lerp(before, target, rate * (0.70 + 0.30 * damping))
        state = {
            "name": self.name,
            "iteration": self.iteration,
            "phase": self.phase,
            "local_wave": local_wave,
            "dao_wave": dao_wave,
            "core_wave": core_wave,
            "light_wave": light_wave,
            "reflection_wave": reflection_wave,
            "coherence_wave": coherence_wave,
            "wave": wave,
            "drive": drive,
            "dao_drive": dao_drive,
            "core_drive": core_drive,
            "light_drive": light_drive,
            "reflection_drive": reflection_drive,
            "coherence_drive": coherence_drive,
            "anti_sync": anti_sync,
            "target": target,
            "permeability_live": self.permeability_live,
            "delta": self.permeability_live - before,
            "never_closed_floor": floor,
        }
        self.phase = (self.phase + PHASE_RATE * (0.5 + 0.5 * drive) * (0.75 + 0.25 * dao_drive) * (0.75 + 0.25 * core_drive) * (0.90 + 0.10 * release_boost)) % 1.0
        self.iteration += 1
        return state


@dataclass
class BoundaryMembrane13:
    left_seam: SeamBreather = field(default_factory=lambda: SeamBreather("seam_12|1", phase=0.0))
    right_seam: SeamBreather = field(default_factory=lambda: SeamBreather("seam_8|9", phase=0.5))
