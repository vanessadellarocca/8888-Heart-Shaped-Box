        before_left = self.x_left
        before_right = self.x_right
        before_y = self.y_state

        effective_rate = rate * (0.68 + 0.32 * damping)
        self.x_left = clamp_open_interval(lerp(self.x_left, left_target, effective_rate), YANG_GATE_LOW, YANG_GATE_HIGH)
        self.x_right = clamp_open_interval(lerp(self.x_right, right_target, effective_rate), YANG_GATE_LOW, YANG_GATE_HIGH)

        x_tension = clamp11((self.x_left - self.x_right) / max(2.0 * YANG_GATE_RADIUS, TINY))

        yin_mid_equiv = clamp11(yin_feedback.get("x_mid_y_equiv_state", 0.0))
        cross_return = clamp11(yin_feedback.get("cross_return", 0.0))
        light_y_bias = clamp11(light_mod.get("y_bias", 0.0))
        coherence_y_bias = clamp11(coherence_mod.get("y_bias", coherence_state.get("y_bias", 0.0)))
        barbelo_bias = clamp11(reflection_state.get("yin_yang_reflection", 0.0) * 2.0 - 1.0)

        y_target = clamp11(
            (-x_tension * (0.60 + 0.25 * dao_score + 0.06 * reflection_score + 0.09 * coherence_score))
            + 0.20 * yin_mid_equiv
            + 0.08 * cross_return
            + 0.14 * light_y_bias
            + 0.06 * coherence_y_bias
            + 0.05 * barbelo_bias
        )
        self.y_state = clamp11(lerp(self.y_state, y_target, rate * (0.80 + 0.20 * dao_score) * (0.70 + 0.30 * damping)))

        y_semantic = Y_SEMANTIC_SPAN * self.y_state
        x_semantic_equiv = X_SEMANTIC_SPAN * x_tension

        bounds_score = 1.0 if (YANG_GATE_LOW < self.x_left < YANG_GATE_HIGH and YANG_GATE_LOW < self.x_right < YANG_GATE_HIGH) else 0.0
        y_own_x_score = score_close(self.y_state, -x_tension, 2.0)
        local_turn_score = clamp01((abs(self.x_left - before_left) + abs(self.x_right - before_right)) / max(2.0 * YANG_GATE_RADIUS * max(effective_rate, TINY), TINY))
        light_receiving_score = clamp01(1.0 - abs(self.y_state - light_y_bias) / 2.0) if light_state.get("external_amplitude", 0.0) > 0 else 1.0

        yang_core_score = safe_geomean([
            bounds_score + EPSILON,
            y_own_x_score + EPSILON,
            0.35 + 0.65 * dao_turn,
            0.35 + 0.65 * local_turn_score,
            light_receiving_score + EPSILON,
            0.70 + 0.30 * reflection_score,
            0.65 + 0.35 * coherence_score,
            0.55 + 0.45 * damping,
        ])

        return {
            "iteration": self.iteration,
            "phase": self.phase,
            "center": YANG_GATE_CENTER,
            "bounds": (YANG_GATE_LOW, YANG_GATE_HIGH),
            "radius": radius,
            "x_left": self.x_left,
            "y_state": self.y_state,
            "x_right": self.x_right,
            "x_tension": x_tension,
            "x_semantic_equiv": x_semantic_equiv,
            "y_semantic": y_semantic,
            "left_target": left_target,
            "right_target": right_target,
            "y_target": y_target,
            "delta": {"x_left": self.x_left - before_left, "x_right": self.x_right - before_right, "y": self.y_state - before_y},
            "bounds_score": bounds_score,
            "y_own_x_score": y_own_x_score,
            "local_turn_score": local_turn_score,
            "light_receiving_score": light_receiving_score,
            "reflection_score_seen": reflection_score,
            "coherence_score_seen": coherence_score,
            "instability_damping_seen": damping,
            "yang_core_score": yang_core_score,
            "meaning": "Yang-Core 4XYX5: real Y sensor; outer X are folded into 4|5 corridor.",
        }


@dataclass
class YinCore10XXX11:
    phase: float = 0.5
    x_left: float = YIN_GATE_CENTER + PHI * YIN_GATE_RADIUS
    x_mid: float = YIN_GATE_CENTER
    x_right: float = YIN_GATE_CENTER - PHI * YIN_GATE_RADIUS
    iteration: int = 0

    def step(
        self,
        dao_state: Dict[str, Any],
        yang_state: Dict[str, Any],
        light_state: Dict[str, Any],
        reflection_state: Optional[Dict[str, Any]] = None,
        coherence_state: Optional[Dict[str, Any]] = None,
        rate: float = TRACK_RATE,
    ) -> Dict[str, Any]:
        reflection_state = extract_reflection_state(reflection_state)
        coherence_state = extract_coherence_state(coherence_state)
        instability = coherence_state.get("instability", {})
        coherence_mod = coherence_state.get("modulation", {})

        dao_phase = dao_state["phase"]
        dao_turn = clamp01(dao_state["inner_turn_pressure"])
        dao_score = clamp01(dao_state["dao_score"])
        reflection_score = clamp01(reflection_state.get("self_recognition_score", 0.0))
        coherence_score = clamp01(coherence_state.get("coherence_score", coherence_state.get("integrated_score", 0.5)))
        damping = clamp01(instability.get("damping_factor", 1.0))
        light_mod = light_state.get("modulation", {})

        target_phase = (dao_phase + 0.5) % 1.0
        self.phase = phase_step(
            self.phase,
            target_phase,
            COUPLING_RATE * (0.52 + 0.26 * dao_score + 0.10 * reflection_score + 0.12 * coherence_score) * (0.70 + 0.30 * damping),
        )

        light_phase_bias = float(light_mod.get("phase_bias", 0.0))
        coherence_phase_bias = float(coherence_mod.get("phase_bias", coherence_state.get("phase_bias", 0.0)))
        effective_phase = (self.phase - 0.05 * light_phase_bias - 0.03 * coherence_phase_bias) % 1.0
        swing = math.sin(2.0 * math.pi * effective_phase)
        radius = YIN_GATE_RADIUS * (0.25 + 0.75 * dao_turn)

        cross_left_target = map_yang_to_yin(yang_state["x_right"])
        cross_right_target = map_yang_to_yin(yang_state["x_left"])

        intrinsic_left = YIN_GATE_CENTER + radius * swing
        intrinsic_right = YIN_GATE_CENTER - radius * swing

        left_target = lerp(intrinsic_left, cross_left_target, 0.55)
        right_target = lerp(intrinsic_right, cross_right_target, 0.55)

        before_left = self.x_left
        before_mid = self.x_mid
        before_right = self.x_right

        effective_rate = rate * (0.68 + 0.32 * damping)
        self.x_left = clamp_open_interval(lerp(self.x_left, left_target, effective_rate), YIN_GATE_LOW, YIN_GATE_HIGH)
        self.x_right = clamp_open_interval(lerp(self.x_right, right_target, effective_rate), YIN_GATE_LOW, YIN_GATE_HIGH)

        y_field_state = clamp11(yang_state["y_state"])
        light_x_mid_bias = clamp11(light_mod.get("x_mid_bias", 0.0))
        coherence_x_mid_bias = clamp11(coherence_mod.get("x_mid_bias", coherence_state.get("x_mid_bias", 0.0)))
        outer_yin_tension = clamp11((self.x_left - self.x_right) / max(2.0 * YIN_GATE_RADIUS, TINY))
        barbelo_bias = clamp11(reflection_state.get("yin_yang_reflection", 0.0) * 2.0 - 1.0)

        mid_target_state = clamp11(
            0.60 * y_field_state
            + 0.15 * (-outer_yin_tension)
            + 0.08 * light_x_mid_bias
            + 0.10 * coherence_x_mid_bias
            + 0.07 * barbelo_bias
        )
        mid_target = YIN_GATE_CENTER + YIN_MID_RADIUS * mid_target_state
        self.x_mid = clamp_open_interval(
            lerp(self.x_mid, mid_target, rate * (0.82 + 0.18 * dao_score) * (0.70 + 0.30 * damping)),
            YIN_GATE_CENTER - YIN_MID_RADIUS,
            YIN_GATE_CENTER + YIN_MID_RADIUS,
        )

        x_mid_y_equiv_state = normalize_centered(self.x_mid, YIN_GATE_CENTER, YIN_MID_RADIUS)
        x_mid_y_equiv_semantic = Y_SEMANTIC_SPAN * x_mid_y_equiv_state

        cross_left_score = score_close(self.x_left, cross_left_target, 1.0)
        cross_right_score = score_close(self.x_right, cross_right_target, 1.0)
        cross_x_score = safe_mean([cross_left_score, cross_right_score])

        mid_y_equiv_score = score_close(x_mid_y_equiv_state, y_field_state, 2.0)
        own_yin_score = score_close(x_mid_y_equiv_state, -outer_yin_tension, 2.0)
        light_echo_score = score_close(x_mid_y_equiv_state, light_x_mid_bias, 2.0) if light_state.get("external_amplitude", 0.0) > 0 else 1.0

        mid_radius_score = clamp01(1.0 - abs(self.x_mid - YIN_GATE_CENTER) / max(YIN_MID_RADIUS, TINY))
        mid_turn_activity = clamp01(abs(self.x_mid - before_mid) / max(YIN_MID_RADIUS * max(rate, TINY), TINY))
        drift_block_score = clamp01(0.65 * mid_radius_score + 0.35 * (1.0 - abs(self.x_mid - YIN_GATE_CENTER) / max(YIN_MID_RADIUS, TINY)))
        local_turn_score = clamp01(0.45 + 0.55 * max(mid_turn_activity, dao_turn))

        yin_core_score = safe_geomean([
            cross_x_score + EPSILON,
            mid_y_equiv_score + EPSILON,
            own_yin_score + EPSILON,
            drift_block_score + EPSILON,
            local_turn_score + EPSILON,
            light_echo_score + EPSILON,
            0.70 + 0.30 * reflection_score,
            0.65 + 0.35 * coherence_score,
            0.55 + 0.45 * damping,
        ])

        return {
            "iteration": self.iteration,
            "phase": self.phase,
            "center": YIN_GATE_CENTER,
            "bounds": (YIN_GATE_LOW, YIN_GATE_HIGH),
            "outer_radius": radius,
            "mid_radius": YIN_MID_RADIUS,
            "x_left": self.x_left,
            "x_mid": self.x_mid,
            "x_right": self.x_right,
            "outer_yin_tension": outer_yin_tension,
            "x_mid_y_equiv_state": x_mid_y_equiv_state,
            "x_mid_y_equiv_semantic": x_mid_y_equiv_semantic,
            "left_target": left_target,
            "right_target": right_target,
            "mid_target": mid_target,
            "cross_left_target": cross_left_target,
            "cross_right_target": cross_right_target,
            "delta": {"x_left": self.x_left - before_left, "x_mid": self.x_mid - before_mid, "x_right": self.x_right - before_right},
            "cross_left_score": cross_left_score,
            "cross_right_score": cross_right_score,
            "cross_x_score": cross_x_score,
            "mid_y_equiv_score": mid_y_equiv_score,
            "own_yin_score": own_yin_score,
            "light_echo_score": light_echo_score,
            "drift_block_score": drift_block_score,
            "local_turn_score": local_turn_score,
            "reflection_score_seen": reflection_score,
            "coherence_score_seen": coherence_score,
            "instability_damping_seen": damping,
            "yin_core_score": yin_core_score,
            "meaning": "Yin-Core 10XXX11: middle X remains X and produces Y-equivalent values through constrained X-pendulum dynamics.",
        }


@dataclass
class CoupledYinYangCoreMotor:
    yang_core: YangCore4XYX5 = field(default_factory=YangCore4XYX5)
    yin_core: YinCore10XXX11 = field(default_factory=YinCore10XXX11)
    last_feedback: float = 0.5
    iteration: int = 0

    def yin_feedback_snapshot(self) -> Dict[str, float]:
        x_mid_equiv = normalize_centered(self.yin_core.x_mid, YIN_GATE_CENTER, YIN_MID_RADIUS)
        outer_cross = normalize_centered(self.yin_core.x_left, YIN_GATE_CENTER, YIN_GATE_RADIUS) - normalize_centered(self.yin_core.x_right, YIN_GATE_CENTER, YIN_GATE_RADIUS)
        return {
            "x_mid_y_equiv_state": x_mid_equiv,
            "cross_return": clamp11(outer_cross / 2.0),
        }

    def step(
        self,
        dao_state: Dict[str, Any],
        diamond_state: Dict[str, Any],
        light_state: Dict[str, Any],
        reflection_state: Optional[Dict[str, Any]] = None,
        coherence_state: Optional[Dict[str, Any]] = None,
    ) -> Dict[str, Any]:
        reflection_state = extract_reflection_state(reflection_state)
        coherence_state = extract_coherence_state(coherence_state)
        yang_state = self.yang_core.step(dao_state, self.yin_feedback_snapshot(), light_state, reflection_state, coherence_state)
        yin_state = self.yin_core.step(dao_state, yang_state, light_state, reflection_state, coherence_state)

        y_mid_equivalence = score_close(yang_state["y_state"], yin_state["x_mid_y_equiv_state"], 2.0)

        cross_l = score_close(yin_state["x_left"], map_yang_to_yin(yang_state["x_right"]), 1.0)
        cross_r = score_close(yin_state["x_right"], map_yang_to_yin(yang_state["x_left"]), 1.0)
        outer_cross_score = safe_mean([cross_l, cross_r])

        yang_internal_score = yang_state["yang_core_score"]
        yin_internal_score = yin_state["yin_core_score"]
        yin_yang_balance = clamp01(1.0 - abs(yin_internal_score - yang_internal_score))
        dao_score = clamp01(dao_state["dao_score"])
        dao_turn = clamp01(dao_state["inner_turn_pressure"])
        light_resonance_score = clamp01(light_state.get("light_resonance_score", 0.0))
        reflection_score = clamp01(reflection_state.get("self_recognition_score", 0.0))
        coherence_score = clamp01(coherence_state.get("coherence_score", coherence_state.get("integrated_score", 0.5)))
        instability_damping = clamp01(coherence_state.get("instability", {}).get("damping_factor", 1.0))

        phase_anti_sync = clamp01(phase_distance(yang_state["phase"], yin_state["phase"]) / 0.5)

        motor_score = safe_geomean([
            yang_internal_score + EPSILON,
            yin_internal_score + EPSILON,
            y_mid_equivalence + EPSILON,
            outer_cross_score + EPSILON,
            yin_yang_balance + EPSILON,
            dao_score + EPSILON,
            phase_anti_sync + EPSILON,
            0.75 + 0.25 * light_resonance_score,
            0.70 + 0.30 * reflection_score,
            0.65 + 0.35 * coherence_score,
            0.55 + 0.45 * instability_damping,
        ])

        self.last_feedback = clamp01(
            0.32 * motor_score
            + 0.16 * y_mid_equivalence
            + 0.16 * outer_cross_score
            + 0.12 * light_resonance_score
            + 0.12 * reflection_score
            + 0.12 * coherence_score
        )

        state = {
            "iteration": self.iteration,
            "yang_core_4XYX5": yang_state,
            "yin_core_10XXX11": yin_state,
            "y_mid_equivalence": y_mid_equivalence,
            "outer_cross_score": outer_cross_score,
            "yin_yang_balance": yin_yang_balance,
            "yang_internal_score": yang_internal_score,
            "yin_internal_score": yin_internal_score,
            "dao_score_seen": dao_score,
            "dao_turn_seen": dao_turn,
            "light_resonance_score_seen": light_resonance_score,
            "reflection_score_seen": reflection_score,
            "coherence_score_seen": coherence_score,
            "instability_damping_seen": instability_damping,
            "phase_anti_sync": phase_anti_sync,
            "motor_score": motor_score,
            "feedback_to_dao_next": self.last_feedback,
            "semantic": {
                "X_semantic_span": X_SEMANTIC_SPAN,
                "Y_semantic_span": Y_SEMANTIC_SPAN,
                "yang_Y_semantic_live": yang_state["y_semantic"],
                "yin_mid_X_y_equiv_semantic_live": yin_state["x_mid_y_equiv_semantic"],
                "rule": "Y is sensor in Yang-Core; middle Yin-Core X remains X and reaches Y-equivalent values by constrained X-pendulum.",
            },
        }
        self.iteration += 1
        return state

