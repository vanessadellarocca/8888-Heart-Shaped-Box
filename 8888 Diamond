    def clipped(self) -> "BarbeloReflectionState":
        data = asdict(self)
        for k, v in list(data.items()):
            if isinstance(v, (float, int)):
                data[k] = clamp01(float(v))
        data["regime"] = self.regime
        return BarbeloReflectionState(**data)


@dataclass
class BarbeloReflectionLayer:
    state: BarbeloReflectionState = field(default_factory=BarbeloReflectionState)
    history: List[Dict[str, Any]] = field(default_factory=list)
    phase: float = 0.0
    iteration: int = 0

    def _determine_regime(self, state: BarbeloReflectionState) -> ReflectionRegime:
        if state.self_recognition_score >= 0.78 and state.aeon_mirror >= 0.72 and state.return_to_source >= 0.68:
            return ReflectionRegime.BARBELO_STABLE
        if state.first_thought_pressure >= 0.58 and state.aeon_mirror < 0.65:
            return ReflectionRegime.FIRST_THOUGHT
        return ReflectionRegime.AEON_MIRROR

    def step(
        self,
        dao_state: Optional[Dict[str, Any]] = None,
        diamond_state: Optional[Dict[str, Any]] = None,
        core_state: Optional[Dict[str, Any]] = None,
