def clamp01(x: float) -> float:
    return max(0.0, min(1.0, float(x)))


def clamp11(x: float) -> float:
    return max(-1.0, min(1.0, float(x)))


def lerp(a: float, b: float, t: float) -> float:
    t = clamp01(t)
    return (1.0 - t) * float(a) + t * float(b)


def safe_mean(values: List[float], default: float = 0.0) -> float:
    vals = [float(v) for v in values if v is not None]
    return sum(vals) / len(vals) if vals else default


def safe_geomean(values: List[float], default: float = 0.0) -> float:
    vals = [max(0.0, float(v)) for v in values]
    if not vals:
        return default
    if any(v <= 0.0 for v in vals):
        return 0.0
    prod = 1.0
    for v in vals:
        prod *= v
    return prod ** (1.0 / len(vals))


def phase_delta(current: float, target: float) -> float:
    delta = (target - current) % 1.0
    if delta > 0.5:
        delta -= 1.0
    return delta


def phase_step(current: float, target: float, rate: float) -> float:
    return (current + clamp01(rate) * phase_delta(current, target)) % 1.0


def phase_distance(a: float, b: float) -> float:
    return abs(phase_delta(a, b))


def score_close(a: float, b: float, scale: float) -> float:
    return clamp01(1.0 - abs(float(a) - float(b)) / max(float(scale), TINY))


def normalize_centered(x: float, center: float, radius: float) -> float:
    return clamp11((float(x) - float(center)) / max(float(radius), TINY))


def clamp_open_interval(x: float, low: float, high: float, eps: float = EPSILON) -> float:
    return max(low + eps, min(high - eps, float(x)))


def map_yang_to_yin(x_yang: float) -> float:
    return float(x_yang) + 6.0


def map_yin_to_yang(x_yin: float) -> float:
    return float(x_yin) - 6.0


def triangular(n: int) -> int:
    return n * (n + 1) // 2


def extract_reflection_state(reflection_payload: Optional[Dict[str, Any]]) -> Dict[str, Any]:
    if not reflection_payload:
        return {}
    if "state" in reflection_payload and isinstance(reflection_payload["state"], dict):
