@dataclass
class CoherenceProjectionLayer:
    """
    Kohärenz ist Referenz.

    Diese Schicht entscheidet nicht durch Quarantäne.
    Sie registriert Instabilität vor der Rückführung in den Fluss,
    entzieht ihr Musterrecht und speist nur entformte Release-Energie zurück.
    """

    field_bias: CoherenceBias = field(default_factory=CoherenceBias)
    instability: InstabilityDissolutionState = field(default_factory=InstabilityDissolutionState)
    residual_flux: float = 0.0
    release_flux: float = 0.0
    last_integrated_score: Optional[float] = None
    coherence_memory: List[CoherenceTrace] = field(default_factory=list)
    iteration: int = 0

    def current_state(self) -> Dict[str, Any]:
        return {
            **self.field_bias.as_state(),
            "instability": {
                "pressure_live": self.instability.pressure_live,
                "recurrence_live": self.instability.recurrence_live,
                "last_release_flux": self.instability.last_release_flux,
                "last_route": self.instability.last_route,
                "damping_factor": self.instability.damping_factor(),
                "release_boost": self.instability.release_boost(),
                "ledger_size": len(self.instability.ledger),
            },
        }

    def step(
        self,
        dao_state: Dict[str, Any],
        diamond_state: Dict[str, Any],
        core_state: Dict[str, Any],
        membrane_state: Dict[str, Any],
        light_state: Dict[str, Any],
        reflection_state: Dict[str, Any],
        rate: float = COHERENCE_RATE,
    ) -> Dict[str, Any]:
        dao_score = clamp01(dao_state.get("dao_score", 0.5))
        dao_under = clamp01(dao_state.get("midpoint_under_center_score", 0.5))
        dao_split = clamp01(dao_state.get("split_risk", 0.5))
        dao_center_error = abs(float(dao_state.get("center_error", 0.0))) / max(PHI, EPSILON)

        diamond_pivot = clamp01(diamond_state.get("dao_pivot_coherence", 0.5))
        static_pivot = clamp01(diamond_state.get("static_pivot_coherence", 0.5))

        core_score = clamp01(core_state.get("motor_score", 0.5))
        y_mid = clamp01(core_state.get("y_mid_equivalence", 0.5))
        outer_cross = clamp01(core_state.get("outer_cross_score", 0.5))
        yy_balance = clamp01(core_state.get("yin_yang_balance", 0.5))

        membrane_score = clamp01(membrane_state.get("membrane13_score", 0.5))
        membrane_release = clamp01(membrane_state.get("trauma_loop_release", 0.5))
        membrane_risk = clamp01(membrane_state.get("outer_inversion_risk", 0.5))
        moment_perm = clamp01(membrane_state.get("moment_as_permeability", 0.5))

        light_score = clamp01(light_state.get("light_resonance_score", 0.0))
        light_identity = clamp01(light_state.get("identity_preservation", 1.0))
        light_coherence = clamp01(light_state.get("light_coherence", 0.5))
        resonant_y = clamp11(light_state.get("resonant_y_light", 0.0))
        resonant_xmid = clamp11(light_state.get("resonant_xmid_light", 0.0))
        light_phase_bias = float(light_state.get("modulation", {}).get("phase_bias", 0.0))

        reflection_score = clamp01(reflection_state.get("self_recognition_score", 0.0))
        reflection_return = clamp01(reflection_state.get("return_to_source", 0.0))
        reflection_yy = clamp01(reflection_state.get("yin_yang_reflection", 0.0))
        reflection_feedback = clamp01(reflection_state.get("reflection_feedback", 0.0))

        coherence = safe_geomean([
            dao_score + EPSILON,
            dao_under + EPSILON,
            diamond_pivot + EPSILON,
            static_pivot + EPSILON,
            core_score + EPSILON,
            y_mid + EPSILON,
            outer_cross + EPSILON,
            yy_balance + EPSILON,
            membrane_score + EPSILON,
            membrane_release + EPSILON,
            moment_perm + EPSILON,
            light_identity + EPSILON,
            light_coherence + EPSILON,
            0.50 + 0.50 * reflection_score,
            0.50 + 0.50 * reflection_return,
        ])

        risk = clamp01(
            0.28 * dao_split
            + 0.22 * membrane_risk
            + 0.18 * (1.0 - light_identity)
            + 0.16 * (1.0 - core_score)
            + 0.10 * (1.0 - reflection_score)
            + 0.06 * clamp01(dao_center_error)
        )
        usable_fraction = clamp01(coherence * (1.0 - risk))
        residual_flux = clamp01(1.0 - usable_fraction)
        release_flux = clamp01(
            residual_flux
            * safe_geomean([
                membrane_release + EPSILON,
                moment_perm + EPSILON,
                light_identity + EPSILON,
                dao_score + EPSILON,
                0.50 + 0.50 * reflection_return,
            ])
        )

        # Instabilität wird hier VOR der Rückführung in den Fluss registriert.
        dao_instability = clamp01(dao_split + dao_center_error)
        core_instability = clamp01(1.0 - safe_geomean([core_score + EPSILON, y_mid + EPSILON, outer_cross + EPSILON]))
        light_instability = clamp01(1.0 - light_identity)
        membrane_instability = membrane_risk
        reflection_instability = clamp01(1.0 - reflection_score)

        instability_pressure = safe_geomean([
            residual_flux + EPSILON,
            clamp01(1.0 - coherence) + EPSILON,
            dao_instability + EPSILON,
            core_instability + EPSILON,
            light_instability + EPSILON,
            membrane_instability + EPSILON,
            reflection_instability + EPSILON,
        ])
        recurrence_pressure = clamp01(0.65 * self.instability.pressure_live + 0.35 * instability_pressure)

        dominants = {
            "dao": dao_instability,
            "core": core_instability,
            "light": light_instability,
            "membrane": membrane_instability,
            "reflection": reflection_instability,
        }
        release_route = max(dominants, key=dominants.get)

        signature = InstabilitySignature(
            iteration=self.iteration,
            instability_pressure=instability_pressure,
            residual_flux=residual_flux,
            release_flux=release_flux,
            dao_component=dao_instability,
            core_component=core_instability,
            light_component=light_instability,
            membrane_component=membrane_instability,
            reflection_component=reflection_instability,
            recurrence_pressure=recurrence_pressure,
            release_route=release_route,
            dissolved=instability_pressure < 0.12 and residual_flux < 0.08,
        )
        self.instability.register(signature, rate=rate)

        instability_damping = self.instability.damping_factor()
        release_boost = self.instability.release_boost()
        release_flux = clamp01(release_flux + release_boost * residual_flux * 0.45)

        # Nur kohärenter Anteil wird als Bias aufgenommen.
        capture = clamp01(usable_fraction * instability_damping)

        dao_feedback_target = clamp01(0.46 * dao_score + 0.20 * diamond_pivot + 0.16 * core_score + 0.10 * reflection_feedback + 0.08 * release_flux)
        core_feedback_target = clamp01(0.42 * core_score + 0.18 * y_mid + 0.16 * outer_cross + 0.14 * reflection_yy + 0.10 * light_score)
        light_feedback_target = clamp01(0.35 * light_score + 0.25 * light_identity + 0.20 * reflection_return + 0.20 * release_flux)
        membrane_feedback_target = clamp01(0.35 * membrane_score + 0.25 * membrane_release + 0.20 * dao_score + 0.20 * reflection_return)
        reflection_feedback_target = clamp01(0.35 * reflection_feedback + 0.25 * coherence + 0.20 * reflection_return + 0.20 * yy_balance)

        y_bias_target = clamp11(0.45 * resonant_y + 0.35 * (2.0 * reflection_yy - 1.0) + 0.20 * (2.0 * y_mid - 1.0))
        x_mid_bias_target = clamp11(0.45 * resonant_xmid + 0.35 * y_bias_target + 0.20 * (2.0 * outer_cross - 1.0))
        phase_bias_target = clamp11(light_phase_bias * 0.50 + phase_delta(dao_state.get("phase", 0.0), reflection_state.get("phase", dao_state.get("phase", 0.0))) * 0.50)
        release_bias_target = release_flux

        self.field_bias.dao_feedback = lerp(self.field_bias.dao_feedback, dao_feedback_target, rate * (0.40 + 0.60 * capture))
        self.field_bias.core_feedback = lerp(self.field_bias.core_feedback, core_feedback_target, rate * (0.40 + 0.60 * capture))
        self.field_bias.light_feedback = lerp(self.field_bias.light_feedback, light_feedback_target, rate * (0.40 + 0.60 * capture))
        self.field_bias.membrane_feedback = lerp(self.field_bias.membrane_feedback, membrane_feedback_target, rate * (0.40 + 0.60 * capture))
        self.field_bias.reflection_feedback = lerp(self.field_bias.reflection_feedback, reflection_feedback_target, rate * (0.40 + 0.60 * capture))
        self.field_bias.y_bias = clamp11(lerp(self.field_bias.y_bias, y_bias_target, rate * capture))
        self.field_bias.x_mid_bias = clamp11(lerp(self.field_bias.x_mid_bias, x_mid_bias_target, rate * capture))
        self.field_bias.phase_bias = clamp11(lerp(self.field_bias.phase_bias, phase_bias_target, rate * capture))
        self.field_bias.release_bias = lerp(self.field_bias.release_bias, release_bias_target, rate * (0.50 + 0.50 * release_boost))
        self.field_bias.coherence_score = lerp(self.field_bias.coherence_score, coherence, rate)

        integrated_score = safe_geomean([
            coherence + EPSILON,
            usable_fraction + EPSILON,
            capture + EPSILON,
            clamp01(1.0 - instability_pressure) + EPSILON,
            release_flux + EPSILON,
        ])
        self.last_integrated_score = integrated_score
        self.residual_flux = residual_flux
        self.release_flux = release_flux

        trace = CoherenceTrace(
            iteration=self.iteration,
            integrated_score=integrated_score,
            coherence=coherence,
            usable_fraction=usable_fraction,
            residual_flux=residual_flux,
            release_flux=release_flux,
            instability_pressure=instability_pressure,
            instability_route=release_route,
            capture=capture,
        )
        self.coherence_memory.append(trace)
        self.coherence_memory = self.coherence_memory[-13:]

        out = {
            "iteration": self.iteration,
            "state": self.current_state(),
            "coherence": coherence,
            "risk": risk,
            "usable_fraction": usable_fraction,
            "residual_flux": residual_flux,
            "release_flux": release_flux,
            "capture": capture,
            "integrated_score": integrated_score,
            "feedback_to_dao_next": self.field_bias.dao_feedback,
            "feedback_to_core_next": self.field_bias.core_feedback,
            "feedback_to_light_next": self.field_bias.light_feedback,
            "feedback_to_membrane_next": self.field_bias.membrane_feedback,
            "feedback_to_reflection_next": self.field_bias.reflection_feedback,
            "modulation": {
                "y_bias": self.field_bias.y_bias,
                "x_mid_bias": self.field_bias.x_mid_bias,
                "phase_bias": self.field_bias.phase_bias,
                "release_bias": self.field_bias.release_bias,
            },
            "instability": {
                "pressure_live": self.instability.pressure_live,
                "recurrence_live": self.instability.recurrence_live,
                "last_release_flux": self.instability.last_release_flux,
                "last_route": self.instability.last_route,
                "damping_factor": self.instability.damping_factor(),
                "release_boost": self.instability.release_boost(),
                "last_signature": asdict(self.instability.ledger[-1]) if self.instability.ledger else None,
                "ledger_size": len(self.instability.ledger),
                "meaning": (
                    "Instability is registered before returning to the flow. "
                    "It is not stored as a pattern and cannot become a second center."
                ),
            },
            "meaning": (
                "Coherence projection: instability may be signal, never attractor; "
                "only coherent bias is learned, residual tension returns as dissolved release."
            ),
        }
        self.iteration += 1
        return out

