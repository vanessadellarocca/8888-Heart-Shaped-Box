# ENERGIE-BERECHNUNG â€” aus Code 1 (phi_coherence, fusion_like_gain, net)
# ============================================================

def compute_energy(core: CorePairState, dao: DaoBreathState,
                   membrane: MembranePairState, heart: HeartArcState,
                   light: LightResonanceState) -> Dict[str, float]:
    """
    fusion_like_gain: geomean aller KohÃ¤renz-Aspekte Ã— (1 âˆ’ leakage)
    net_coherence_gain: fusion âˆ’ leakage âˆ’ damping, zentriert bei 0.5
    phi_coherence: phase_coherence Ã— phi_ratio(cce, edge_braid) Ã— dao_score
    """
    phi_coherence = safe_geomean([
        core.phase_coherence + EPSILON,
        phi_ratio_score(core.center_cross_event + EPSILON,
                        core.edge_braid + EPSILON) + EPSILON,
        dao.dao_score + EPSILON,
    ])
    outward_leakage = clamp01(
        max(membrane.inversion_risk_12_1, membrane.inversion_risk_8_9)
        + core.outward_pressure * (1.0 - core.edge_braid)
    )
    damping = clamp01(
        (1.0 - light.identity_preservation) * 0.30
        + dao.split_risk * 0.25
    )
    fusion_like_gain = safe_geomean([
        core.center_cross_event + EPSILON,
        core.edge_braid + EPSILON,
        core.inward_pull + EPSILON,
        phi_coherence + EPSILON,
        membrane.pulse + EPSILON,
        heart.return_force + EPSILON,
        light.light_score + EPSILON,
    ]) * (1.0 - outward_leakage)
    net = clamp01(fusion_like_gain - outward_leakage - damping + 0.5)
    return {
        "phi_coherence": phi_coherence,
        "outward_leakage": outward_leakage,
        "damping": damping,
        "fusion_like_gain": clamp01(fusion_like_gain),
        "net_coherence_gain": net,
    }


