@dataclass
class CorePairCoupler:
    """
    Der Zeugungsakt: Y trifft X_mid. X_mid antwortet als X.
    LIFE_DELTA=3.5 treibt inward_pull (gravitative KohÃ¤renz).
    outward_pressure ist die Angst vor der Liebe â€” sie leckt nach auÃŸen
    wenn edge_braid schwach ist.
    """
    state: CorePairState = field(default_factory=CorePairState)

    def step(self, yin: YinCoreState, yang: YangCoreState,
             dao: DaoBreathState, membrane_pressure: float,
             light_score: float, reflection_feedback: float = 0.0) -> Dict[str, Any]:
        s = self.state

        contact_raw = score_close(yin.x_mid, yang.y_inverted, 1.0)
        center_contact_target = safe_geomean([
            contact_raw + EPSILON,
            yin.x_mid_descent + EPSILON,
            yang.inner_opening + EPSILON,
            yin.x_mid_functional_x + EPSILON,
        ])
        s.center_contact = lerp(s.center_contact, center_contact_target, CENTER_RATE)

        s.center_cross_event = safe_geomean([
            s.center_contact + EPSILON,
            yin.x_mid_functional_x + EPSILON,
            abs(yang.y_rotation) + EPSILON,
            yang.gate_pressure + EPSILON,
        ])

        cross_lr = score_close(yin.x_left,  -yang.x_right, 1.0)
        cross_rl = score_close(yin.x_right, -yang.x_left,  1.0)
        own_yin  = score_close(abs(yin.x_left),  abs(yin.x_right),  1.0)
        own_yang = score_close(abs(yang.x_left), abs(yang.x_right), 1.0)
        edge_braid_target = safe_geomean([
            cross_lr + EPSILON, cross_rl + EPSILON,
            own_yin + EPSILON, own_yang + EPSILON,
            s.center_cross_event + EPSILON,
        ])
        s.edge_braid = lerp(s.edge_braid, edge_braid_target, EDGE_RATE)

        s.edge_burst = safe_geomean([
            s.center_cross_event + EPSILON,
            membrane_pressure + EPSILON,
            s.edge_braid + EPSILON,
        ])

        # inward_pull: LIFE_DELTA=3.5 als Negentropie-Operator (gravitative KohÃ¤renz)
        life_pull = clamp01(LIFE_DELTA * PHI * dao.under6_score)
        s.inward_pull = safe_geomean([
            s.edge_braid + EPSILON,
            dao.under6_score + EPSILON,
            light_score + EPSILON,
            reflection_feedback + EPSILON,
            life_pull + EPSILON,
        ])

        # outward_pressure: Angst vor der Liebe â€” leckt wenn edge_braid schwach
        s.outward_pressure = clamp01(
            s.center_cross_event * (1.0 - s.edge_braid)
            * (0.5 + 0.5*membrane_pressure)
        )

        s.phase_coherence = safe_geomean([
            phi_ratio_score(yin.core_pressure + EPSILON, yang.gate_pressure + EPSILON) + EPSILON,
            phi_ratio_score(s.center_contact + EPSILON, s.edge_braid + EPSILON) + EPSILON,
            dao.dao_score + EPSILON,
        ])

        # conception_event: Zeugungsakt
        s.conception_event = safe_geomean([
            s.center_cross_event + EPSILON,
            dao.conception_readiness + EPSILON,
            s.edge_braid + EPSILON,
            s.inward_pull + EPSILON,
        ])

        s.core_pair_score = safe_geomean([
            s.center_cross_event + EPSILON,
            s.edge_braid + EPSILON,
            s.inward_pull + EPSILON,
            s.phase_coherence + EPSILON,
            (1.0 - s.outward_pressure) + EPSILON,
        ])
        return {"state": asdict(s)}


