@dataclass
class CoherenceProjectionLayer:
    """
    KohÃ¤renz ist Referenz, nicht QuarantÃ¤ne.
    InstabilitÃ¤t = Signal, kein Attraktor.
    field_recognition: Feld erkennt Core als sich selbst
    (phi_ratio(field_density, core_score) Ã— arc_balance).
    """
    instability: InstabilityDissolutionState = field(
        default_factory=InstabilityDissolutionState)
    residual_flux: float   = 0.0
    release_flux: float    = 0.0
    field_recognition: float = 0.0
    iteration: int = 0
    dao_feedback:        float = 0.5
    core_feedback:       float = 0.5
    light_feedback:      float = 0.0
    membrane_feedback:   float = 0.5
    reflection_feedback: float = 0.0

    def step(self, dao_score: float, dao_under: float, dao_split: float,
             core_pair_score: float, outer_cross: float, inward_pull: float,
             membrane_score: float, membrane_release: float, membrane_risk: float,
             moment_perm: float, light_score: float, light_identity: float,
             light_coherence: float, reflection_score: float,
             reflection_return: float, reflection_feedback_in: float,
             field_conception_density: float = 0.0,
             arc_balance: float = 0.0) -> Dict[str, Any]:

        coherence = safe_geomean([
            dao_score + EPSILON, dao_under + EPSILON,
            core_pair_score + EPSILON, outer_cross + EPSILON,
            inward_pull + EPSILON, membrane_score + EPSILON,
            membrane_release + EPSILON, moment_perm + EPSILON,
            light_identity + EPSILON, light_coherence + EPSILON,
            (0.5 + 0.5*reflection_score) + EPSILON,
            (0.5 + 0.5*reflection_return) + EPSILON,
            clamp01(COHERENCE_HEADROOM / PHI_BIG) + EPSILON,
        ])

        risk = clamp01(
            0.28*dao_split + 0.22*membrane_risk
            + 0.18*(1.0 - light_identity) + 0.16*(1.0 - core_pair_score)
            + 0.10*(1.0 - reflection_score) + 0.06*(1.0 - arc_balance)
        )

        usable   = clamp01(coherence * (1.0 - risk))
        residual = clamp01(1.0 - usable)
        release  = clamp01(residual * safe_geomean([
            membrane_release + EPSILON, moment_perm + EPSILON,
            light_identity + EPSILON, dao_score + EPSILON,
            (0.5 + 0.5*reflection_return) + EPSILON,
        ]))

        dao_i  = clamp01(dao_split)
        core_i = clamp01(1.0 - safe_geomean([core_pair_score + EPSILON, outer_cross + EPSILON]))
        light_i = clamp01(1.0 - light_identity)
        mem_i  = membrane_risk
        refl_i = clamp01(1.0 - reflection_score)

        instab_pressure = safe_geomean([
            residual + EPSILON, clamp01(1.0 - coherence) + EPSILON,
            dao_i + EPSILON, core_i + EPSILON,
            light_i + EPSILON, mem_i + EPSILON, refl_i + EPSILON,
        ])
        recurrence = clamp01(0.65*self.instability.pressure_live + 0.35*instab_pressure)

        dominants = {"dao": dao_i, "core": core_i, "light": light_i,
                     "membrane": mem_i, "reflection": refl_i}
        route = max(dominants, key=dominants.get)

        sig = InstabilitySignature(
            iteration=self.iteration,
            instability_pressure=instab_pressure,
            residual_flux=residual, release_flux=release,
            dao_component=dao_i, core_component=core_i,
            light_component=light_i, membrane_component=mem_i,
            reflection_component=refl_i,
            recurrence_pressure=recurrence, release_route=route,
            dissolved=instab_pressure < 0.12 and residual < 0.08,
        )
        self.instability.register(sig)

        damping = self.instability.damping_factor()
        rb      = self.instability.release_boost()
        release = clamp01(release + rb * residual * 0.45)
        capture = clamp01(usable * damping)

        # field_recognition: Feld erkennt Core als sich selbst
        field_core_phi = phi_ratio_score(
            field_conception_density + EPS, core_pair_score + EPS
        )
        self.field_recognition = lerp(
            self.field_recognition,
            safe_geomean([
                field_core_phi + EPSILON,
                arc_balance + EPSILON,
                (0.5 + 0.5*coherence) + EPSILON,
            ]),
            COUPLING_RATE
        )

        eff_rate = COHERENCE_RATE * (0.40 + 0.60*capture)
        self.dao_feedback = lerp(self.dao_feedback,
            clamp01(0.46*dao_score + 0.16*core_pair_score
                    + 0.10*reflection_feedback_in + 0.28*release), eff_rate)
        self.core_feedback = lerp(self.core_feedback,
            clamp01(0.42*core_pair_score + 0.18*outer_cross
                    + 0.16*inward_pull + 0.24*reflection_feedback_in), eff_rate)
        self.light_feedback = lerp(self.light_feedback,
            clamp01(0.35*light_score + 0.25*light_identity
                    + 0.20*reflection_return + 0.20*release), eff_rate)
        self.membrane_feedback = lerp(self.membrane_feedback,
            clamp01(0.35*membrane_score + 0.25*membrane_release
                    + 0.20*dao_score + 0.20*reflection_return), eff_rate)
        self.reflection_feedback = lerp(self.reflection_feedback,
            clamp01(0.35*reflection_feedback_in + 0.25*coherence
                    + 0.20*reflection_return + 0.20*outer_cross), eff_rate)

        self.residual_flux = residual
        self.release_flux  = release
        self.iteration += 1

        return {
            "coherence": coherence, "risk": risk,
            "usable_fraction": usable,
            "residual_flux": residual, "release_flux": release,
            "capture": capture,
            "field_recognition": self.field_recognition,
            "instability": {
                "pressure_live": self.instability.pressure_live,
                "damping": damping, "release_boost": rb,
                "dissolved": sig.dissolved, "route": route,
            },
            "feedback_to_dao_next":        self.dao_feedback,
            "feedback_to_core_next":       self.core_feedback,
            "feedback_to_light_next":      self.light_feedback,
            "feedback_to_membrane_next":   self.membrane_feedback,
            "feedback_to_reflection_next": self.reflection_feedback,
        }


