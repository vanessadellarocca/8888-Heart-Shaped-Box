    state: HeartArcState = field(default_factory=HeartArcState)

    def step(self, center_cross_event: float, edge_braid: float,
             membrane_release: float, dao_score: float,
             schumann_pulse: float = 0.5,
             field_conception_density: float = 0.0,
             core_pair_score: float = 0.0) -> Dict[str, Any]:
        s = self.state
        schumann_arc = SCHUMANN_REL / 8.0  # â‰ˆ 0.978

        # 1â†’8: Feld sendet Licht zum Core
        l2e_target = safe_geomean([
            center_cross_event + EPSILON,
