@dataclass
class DaoBreath:
    state: DaoBreathState = field(default_factory=DaoBreathState)

    def _radius(self) -> float:
        inward = 0.5 - 0.5 * math.cos(2.0 * math.pi * self.state.phase)
        return R_INNER + (R_OUTER - R_INNER) * (1.0 - inward)

    def step(self, core_feedback: float = 0.5,
             reflection_feedback: float = 0.0,
             instability_damping: float = 1.0,
             release_boost: float = 0.0) -> Dict[str, Any]:
        s = self.state

        # Schumann-Puls: biologischer/physikalischer Feldrhythmus â€” WANN
        s.schumann_phase = phase_step(s.schumann_phase, SCHUMANN_PHASE_RATE)
        s.schumann_pulse = smooth_pulse(s.schumann_phase)

        life_drive = clamp01(LIFE_DELTA / PHI_ANCHOR)  # â‰ˆ 0.309
        eff = clamp01(0.45*core_feedback + 0.20*reflection_feedback
                      + 0.20*life_drive + 0.15*release_boost)
        eff_track = TRACK_RATE * (0.80 + 0.40*eff) * (0.35 + 0.65*instability_damping)
        eff_phase = PHASE_RATE * (0.85 + 0.25*eff)

        r = self._radius()
        s.radius = lerp(s.radius, r, eff_track)
        lower_t = DAO_CENTER - (s.radius + EPSILON)
        upper_t = DAO_CENTER + (s.radius - EPSILON)
        s.lower_live = lerp(s.lower_live, lower_t, eff_track)
        s.upper_live = lerp(s.upper_live, upper_t, eff_track)
        s.midpoint   = (s.lower_live + s.upper_live) / 2.0

        denom = max(R_OUTER - R_INNER, EPS)
        s.inner_turn   = clamp01((R_OUTER - s.radius) / denom)
        s.under6_score = score_close(s.midpoint, DAO_TRACE_CENTER, PHI)
        s.split_risk   = clamp01(
            abs(s.midpoint - DAO_CENTER) / PHI * (1.0 - s.under6_score)
        )

        # conception_readiness: WANN ist der Tanz bereit zum Zeugungsakt?
        s.conception_readiness = safe_geomean([
            s.inner_turn + EPSILON,
            s.schumann_pulse + EPSILON,
            s.under6_score + EPSILON,
            core_feedback + EPSILON,
        ])

        s.dao_score = safe_geomean([
            s.under6_score + EPSILON,
            (1.0 - s.split_risk) + EPSILON,
            s.inner_turn + EPSILON,
            eff + EPSILON,
            (0.5 + 0.5*instability_damping) + EPSILON,
        ])

        center_error = s.midpoint - DAO_TRACE_CENTER

        # direction: wo in der Spirale befinden wir uns?
        # Basiert auf Phase-Position, nicht auf radial_velocity (numerisch instabil).
        # phase=0: outer_phi_boundary (Radius=PHI, Einatmen beginnt)
        # phase=0â†’0.5: inward (Radius sinkt)
        # phase=0.5: inner_turn_upper_touches_6 (Radiusâ‰ˆEPSILON, upper berÃ¼hrt 6)
        # phase=0.5â†’1.0: return_to_phi_boundary (Radius steigt)
        p = s.phase
        if abs(p - 0.5) < 1e-3:
            direction = "inner_turn_upper_touches_6"
        elif p < 1e-3 or p > 1.0 - 1e-3:
            direction = "outer_phi_boundary"
        elif p < 0.5:
            direction = "inward"
        else:
            direction = "return_to_phi_boundary"

        # 3D-Koordinaten der Spirale (fÃ¼r Visualisierung)
        angle = 2.0 * math.pi * s.phase
        upper_xyz = (s.radius * math.cos(angle),
                     s.radius * math.sin(angle),
                     s.upper_live)
        lower_xyz = (s.radius * math.cos(angle + math.pi),
                     s.radius * math.sin(angle + math.pi),
                     s.lower_live)

        s.phase = phase_step(s.phase, eff_phase)
        return {
            "state": asdict(s), "dao_score": s.dao_score,
            "midpoint_under_center_score": s.under6_score,
            "split_risk": s.split_risk, "inner_turn": s.inner_turn,
            "conception_readiness": s.conception_readiness,
            "schumann_pulse": s.schumann_pulse, "phase": s.phase,
            "midpoint": s.midpoint,
            "center_error": center_error,
            "direction": direction,
            "upper_xyz": upper_xyz,
            "lower_xyz": lower_xyz,
            "upper_touches_6": abs(s.upper_live - DAO_CENTER) < 1e-4,
        }

    def exact_inner_turn(self) -> Dict[str, Any]:
        """
        Der BerÃ¼hrungsmoment: wenn Radius â†’ EPSILON berÃ¼hrt upper_live
        exakt die 6. Das ist Kontakt â€” kein Sein. 6 ist nicht Heimat.
        """
        r = R_INNER
        lower_ideal = DAO_CENTER - (r + EPSILON)
        upper_ideal = DAO_CENTER + (r - EPSILON)
        return {
            "radius": r,
            "lower_ideal": lower_ideal,
            "upper_ideal": upper_ideal,
            "midpoint_ideal": (lower_ideal + upper_ideal) / 2.0,
            "upper_touches_6": abs(upper_ideal - DAO_CENTER) < 1e-9,
            "midpoint_is_6_minus_epsilon": abs(
                (lower_ideal + upper_ideal) / 2.0 - DAO_TRACE_CENTER
            ) < 1e-9,
            "meaning": (
                "Im inneren Umkehrpunkt berÃ¼hrt upper_live die 6. "
                "Mittelpunkt bleibt 6âˆ’Îµ. "
                "6 ist Kontakt, nicht statisches Sein."
            ),
        }


