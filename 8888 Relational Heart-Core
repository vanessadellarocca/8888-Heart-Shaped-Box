# SEAM BREATHER â€” aus Code 2 (anti_sync zwischen 12|1 und 8|9)
# ============================================================

@dataclass
class SeamBreather:
    """
    Eine Membrannaht pulsiert.
    anti_sync: 12|1 und 8|9 pulsieren gegenlÃ¤ufig â€”
    wenn eine Ã¶ffnet, tendiert die andere zu schlieÃŸen.
    Das verhindert AuÃŸeninversion: nie beide gleichzeitig weit offen.
    """
    name: str
    phase: float = 0.0
    permeability_live: float = EPSILON

    def step(self, drive: float, dao_score: float, core_score: float,
             reflection_score: float, coherence_score: float,
             damping: float = 1.0, release_boost: float = 0.0,
             schumann_pulse: float = 0.5,
             conception_event: float = 0.0,
             opposite_phase: Optional[float] = None) -> Dict[str, Any]:
        drive = clamp01(drive)
        local_wave = smooth_pulse(self.phase)

        # anti_sync: Abstand zur gegenlÃ¤ufigen Naht
        anti_sync = (clamp01(phase_dist(self.phase, opposite_phase) / 0.5)
                     if opposite_phase is not None else 1.0)

        # Schumann und conception_event geben biologischen Rhythmus
        schumann_membrane = safe_geomean([schumann_pulse + EPSILON, conception_event + EPSILON])

        floor, ceiling = EPSILON, 1.0 - EPSILON
        target = floor + (ceiling - floor) * (
            drive * dao_score * core_score
            * (0.8 + 0.2*reflection_score)
            * (0.8 + 0.2*coherence_score)
            * (0.3 + 0.7*local_wave)
            * (0.5 + 0.5*anti_sync)
            * (0.7 + 0.3*schumann_membrane)
        )
        target = clamp01(target + release_boost * 0.08)

        before = self.permeability_live
        self.permeability_live = lerp(before, target, SEAM_RATE * (0.70 + 0.30*damping))

        self.phase = phase_step(
            self.phase,
            PHASE_RATE * (0.5 + 0.5*drive) * (0.75 + 0.25*dao_score)
        )
        return {
            "name": self.name, "phase": self.phase,
            "permeability_live": self.permeability_live,
            "anti_sync": anti_sync, "local_wave": local_wave,
            "target": target, "delta": self.permeability_live - before,
        }


