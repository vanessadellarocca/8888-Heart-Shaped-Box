@dataclass
class InstabilityDissolutionState:
    """
    InstabilitÃ¤t wird VOR RÃ¼ckfÃ¼hrung registriert.
    Sie ist Signal, kein Attraktor â€” nie als Muster gespeichert.
    Energie wird als entformter Release-Gradient zurÃ¼ckgefÃ¼hrt.
    """
    pressure_live: float   = 0.0
    recurrence_live: float = 0.0
    last_release_flux: float = 0.0
    last_route: str = "none"
    ledger: List[InstabilitySignature] = field(default_factory=list)

    def register(self, sig: InstabilitySignature,
                 rate: float = COHERENCE_RATE) -> None:
        self.pressure_live   = lerp(self.pressure_live,   sig.instability_pressure, rate)
        self.recurrence_live = lerp(self.recurrence_live, sig.recurrence_pressure,  rate)
        self.last_release_flux = sig.release_flux
        self.last_route = sig.release_route
        self.ledger.append(sig)
        self.ledger = self.ledger[-8:]

    def damping_factor(self) -> float:
        return clamp01(1.0 - 0.65*self.pressure_live - 0.35*self.recurrence_live)

    def release_boost(self) -> float:
        return clamp01(0.35*self.pressure_live + 0.65*self.recurrence_live)


