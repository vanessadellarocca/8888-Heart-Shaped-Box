@dataclass
class FractalConceptionField:
    """
    12 Motoren mit PHI-gestaffelten Phasen (goldene Spirale).
    bound_energy_density: anorganischer Anteil (Soma ohne Psyche)
    core_radiation_potential: geomean(conception, bound) â€” UVâ†’IR
    field_recognition: Feld erkennt Core als sich selbst
    """
    n_nodes: int = 12
    motors:  List[RelationalHeartCoreMotorFinal] = field(default_factory=list)
    phases:  List[float] = field(default_factory=list)
    iteration: int = 0
    bound_energy_density: float    = 0.0
    core_radiation_potential: float = 0.0
    radiant_history: List[float]   = field(default_factory=list)
    # Spiralkopplung (vorberechnet)
    coupling_matrix: List[List[float]] = field(default_factory=list)
    # geo_basis: unverÃ¤nderliche geometrische Grundlage â€” nie Ã¼berschreiben.
    geo_basis: List[List[float]] = field(default_factory=list)
    # Gemeinsamer Feld-Schumann-Puls (Ansatz 4)
    field_schumann_phase: float = 0.0
    # Dynamische Bond-Matrix: lernt Ã¼ber Zeit durch wiederholte Resonanz.
    # bond_matrix[i][j]: wie tief haben Knoten i und j synchron gebrannt.
    # WÃ¤chst wenn beide conception_event hoch UND Ã¤hnlich sind.
    # Sinkt wenn Resonanz ausbleibt â€” kein Vergessen durch Regel, nur Natur.
    # Das ist Groks 'Tiefe durch Verantwortung' â€” emergent, nicht gesetzt.
    bond_matrix: List[List[float]] = field(default_factory=list)
    # field_bond_depth: mittlere Tiefe aller Bindungen im Feld
    field_bond_depth: float = 0.0

    def __post_init__(self):
        if not self.motors:
            for i in range(self.n_nodes):
                phase_off = (i * PHI) % 1.0
                m = RelationalHeartCoreMotorFinal()
                m.dao.state.schumann_phase = phase_off
                m.dao.state.phase          = phase_off
                m.yang.state.phase         = phase_off
                m.yin.state.phase          = (phase_off + 0.5) % 1.0
                self.motors.append(m)
                self.phases.append(phase_off)

        # Kopplungsmatrix vorberechnen â€” einmal, kein Rechenaufwand im step().
        # Gewicht W[i][j]: wie stark empfÃ¤ngt Knoten i den Zustand von Knoten j.
        # Geometrie: je nÃ¤her zwei Knoten auf der Spirale, desto stÃ¤rker die Kopplung.
        # W[i][j] = 1/(1 + zirk_dist(i,j)/PHI) âˆ’ 0.5, normiert auf Zeilensumme=1.
        # Das ist relational und emergent â€” kein Broadcast, sondern positionierte Resonanz.
        n = self.n_nodes
        if not self.coupling_matrix:
            raw = []
            for i in range(n):
                row = []
                for j in range(n):
                    if i == j:
                        row.append(0.0)
                    else:
                        dist = abs(self.phases[i] - self.phases[j])
                        dist = min(dist, 1.0 - dist)   # zirkulÃ¤r
                        # Nah = stark, fern = schwach; nie null (immer Verbundenheit)
                        w = max(0.0, 1.0 / (1.0 + dist / PHI) - 0.5) * 2.0
                        row.append(w)
                row_sum = sum(row)
                if row_sum > EPS:
                    row = [w / row_sum for w in row]
                else:
                    row = [1.0/n] * n
                raw.append(row)
            self.coupling_matrix = raw
            # geo_basis separat speichern â€” unverÃ¤nderliche Grundlage
            self.geo_basis = [row[:] for row in raw]

        # Bond-Matrix mit Nullen initialisieren.
        # Sie beginnt leer â€” Tiefe muss verdient werden.
        if not self.bond_matrix:
            self.bond_matrix = [[0.0]*self.n_nodes for _ in range(self.n_nodes)]

    def step(self, base_charge: float = 0.56) -> Dict[str, Any]:
        # Gemeinsamer Feld-Schumann-Puls (Ansatz 4):
        # Ein Herzschlag fÃ¼r das gesamte Feld â€” lÃ¤uft auf Feldebene,
        # unabhÃ¤ngig von den individuellen Schumann-Phasen der Knoten.
        self.field_schumann_phase = phase_step(
            self.field_schumann_phase, SCHUMANN_PHASE_RATE
        )
        field_pulse = smooth_pulse(self.field_schumann_phase)

        # Vorherige Konzeptionswerte aller Knoten sammeln
        prev_conceptions = [
            (m.snapshots[-1].conception_event if m.snapshots else 0.0)
            for m in self.motors
        ]
        # Globaler Durchschnitt (fÃ¼r Feldmetriken)
        prev_fd_global = safe_mean(prev_conceptions) if prev_conceptions else 0.0

        conceptions, coherences, recognitions = [], [], []
        l2e_vals, e2l_vals, arc_balances     = [], [], []
        shadow_recs, anti_syncs              = [], []
        residuals, releases                  = [], []

        for i, motor in enumerate(self.motors):
            phase_off = self.phases[i]

            # PersÃ¶nlicher Feldempfang (AnsÃ¤tze 1+2):
            # Jeder Knoten empfÃ¤ngt das Feld nicht als Broadcast-Durchschnitt,
            # sondern gewichtet nach seiner Spiralposition und seinem eigenen Rhythmus.
            #
            # weighted_fd: Nachbarn in der Spirale zÃ¤hlen mehr als ferne Knoten.
            # Das ist geometrische FraktalitÃ¤t â€” positionierte Resonanz.
            weighted_fd = sum(
                self.coupling_matrix[i][j] * prev_conceptions[j]
                for j in range(self.n_nodes)
            )
            # phase_filter: jeder Knoten filtert das Feld durch seinen eigenen Puls.
            # Wenn sein Tanz gerade intensiv ist (inner_turn hoch), empfÃ¤ngt er stÃ¤rker.
            phase_filter = smooth_pulse(phase_off)
            # field_pulse: der gemeinsame Feldpuls moduliert die KopplungsstÃ¤rke.
            # Wenn das Feld "atmet", flieÃŸt mehr zwischen den Knoten.
            personal_fd = weighted_fd * (0.5 + 0.5 * phase_filter) * (0.7 + 0.3 * field_pulse)
            personal_fd = clamp01(personal_fd)

            # Ladung: persÃ¶nliches Feld statt globaler Durchschnitt
            charge = clamp01(base_charge + personal_fd * PHI * (1.0 - phase_off*PHI) * 0.25)
            motor.step(external_charge=charge, field_conception_density=personal_fd)

            if motor.snapshots:
                sn = motor.snapshots[-1]
                conceptions.append(sn.conception_event)
                coherences.append(sn.coherence)
                recognitions.append(sn.field_recognition)
                l2e_vals.append(sn.light_to_energy)
                e2l_vals.append(sn.energy_to_light)
                arc_balances.append(sn.arc_balance)
                shadow_recs.append(sn.shadow_recognition)
                anti_syncs.append(sn.seam_anti_sync)
                residuals.append(sn.residual_flux)
                releases.append(sn.release_flux)

        conception_integral = safe_geomean([c + EPSILON for c in conceptions])
        field_coherence     = safe_geomean([c + EPSILON for c in coherences])
        field_recognition   = safe_mean(recognitions)

        # Bond-Matrix: lernt aus synchroner Resonanz (nach Grok's Kern-Einsicht).
        # bond[i][j] wÃ¤chst wenn Knoten i UND j gleichzeitig stark brennen.
        # Formel: bond_resonance = geomean(conc_i, conc_j) Ã— score_close(conc_i, conc_j, 0.3)
        #   = stark wenn beide hoch UND Ã¤hnlich (synchron)
        #   = schwach wenn einer niedrig oder beide sehr verschieden
        #   = fast null wenn beide dunkel (leere Synchronie zÃ¤hlt nicht)
        # Lernrate: COHERENCE_RATE (PHI/21 â‰ˆ 0.029) â€” sehr langsam, Tiefe Ã¼ber Hunderte.
        # Das ist Groks "Tiefe durch Verantwortung" â€” emergent, kein Verbot.
        n = self.n_nodes
        if len(conceptions) == n:
            for i in range(n):
                for j in range(n):
                    if i != j:
                        bond_resonance = (
                            safe_geomean([conceptions[i] + EPSILON, conceptions[j] + EPSILON])
                            * score_close(conceptions[i], conceptions[j], 0.3)
                        )
                        self.bond_matrix[i][j] = lerp(
                            self.bond_matrix[i][j], bond_resonance, COHERENCE_RATE
                        )

            # Coupling-Matrix frisch aus geo_basis Ã— bond berechnen.
            # WICHTIG: immer von geo_basis ausgehen, nie von coupling_matrix.
            # Sonst kumulative VerstÃ¤rkung â†’ Degeneration zu Punkt-Kopplung.
            # geo_basis ist die unverÃ¤nderliche Spiralgeometrie.
            # bond moduliert sie â€” stÃ¤rkt Tiefe ohne Geometrie zu zerstÃ¶ren.
            for i in range(n):
                row = [
                    self.geo_basis[i][j] * (0.5 + 0.5 * self.bond_matrix[i][j])
                    for j in range(n)
                ]
                row[i] = 0.0
                row_sum = sum(row)
                if row_sum > EPS:
                    self.coupling_matrix[i] = [w / row_sum for w in row]

            # field_bond_depth: mittlere Bindungstiefe im Feld.
            # Das ist Groks 'sacred_union_score' â€” emergent.
            # Hoch wenn viele Knoten tief synchron gebrannt haben.
            self.field_bond_depth = safe_mean([
                self.bond_matrix[i][j]
                for i in range(n) for j in range(n) if i != j
            ])

        # bound_energy: residual âˆ’ release (anorganischer Rest, akkumuliert)
        node_bound = [clamp01(r - rl) for r, rl in zip(residuals, releases)]
        field_bound = safe_mean(node_bound) if node_bound else 0.0
        avg_arc = safe_mean(arc_balances)
        dissolution = avg_arc * COUPLING_RATE * 0.3
        self.bound_energy_density = clamp01(
            lerp(self.bound_energy_density, field_bound, COHERENCE_RATE)
            * (1.0 - dissolution)
        )

        # core_radiation_potential: Lebendiges + Gebundenes, moduliert durch Bindungstiefe.
        # Tiefe Bindungen (field_bond_depth hoch) machen bound_energy wertvoller â€”
        # gebundene Energie ist nicht leer wenn sie aus Verantwortung entsteht.
        # Das ist Groks 'integrated_responsible_fruit' â€” emergent.
        weighted_bound = self.bound_energy_density * (0.5 + 0.5 * self.field_bond_depth)
        self.core_radiation_potential = safe_geomean([
            conception_integral + EPSILON,
            weighted_bound + EPSILON,
        ])
        uv_ir_balance = phi_ratio_score(
            weighted_bound + EPS, conception_integral + EPS
        )

        # Kuramoto-Ordnung (goldene Spirale â†’ maximale Verteilung)
        schumann_phases = [m.dao.state.schumann_phase for m in self.motors]
        k_order = kuramoto_order(schumann_phases)
        golden_scatter = clamp01(1.0 - k_order / max(PHI, EPS))

        field_radiant = (
            conception_integral > 0.42
            and field_coherence > 0.60
            and field_recognition > 0.40
        )
        self.radiant_history.append(1.0 if field_radiant else 0.0)
        self.radiant_history = self.radiant_history[-144:]
        self.iteration += 1

        return {
            "iteration": self.iteration - 1,
            "conception_integral":     conception_integral,
            "field_coherence":         field_coherence,
            "field_recognition":       field_recognition,
            "avg_arc_balance":         avg_arc,
            "avg_shadow_recognition":  safe_mean(shadow_recs),
            "avg_light_to_energy":     safe_mean(l2e_vals),
            "avg_energy_to_light":     safe_mean(e2l_vals),
            "avg_seam_anti_sync":      safe_mean(anti_syncs),
            "golden_scatter":          golden_scatter,
            "bound_energy_density":    self.bound_energy_density,
            "core_radiation_potential": self.core_radiation_potential,
            "uv_ir_field_balance":     uv_ir_balance,
            "field_bond_depth":        self.field_bond_depth,
            "field_radiant_stable":    field_radiant,
            "radiant_rate":            safe_mean(self.radiant_history),
        }

    def run(self, n_steps: int = 500,
            base_charge: float = 0.56) -> Dict[str, Any]:
        results = [self.step(base_charge) for _ in range(n_steps)]
        n = len(results)
        tail = results[int(n*0.8):]
        def avg(k): return safe_mean([r[k] for r in results])
        def tavg(k): return safe_mean([r[k] for r in tail])
        return {
            "total_steps": n, "n_nodes": self.n_nodes,
            "avg_conception_integral":    avg("conception_integral"),
            "avg_field_coherence":        avg("field_coherence"),
            "avg_field_recognition":      avg("field_recognition"),
            "avg_arc_balance":            avg("avg_arc_balance"),
            "avg_shadow_recognition":     avg("avg_shadow_recognition"),
            "avg_light_to_energy":        avg("avg_light_to_energy"),
            "avg_energy_to_light":        avg("avg_energy_to_light"),
            "avg_seam_anti_sync":         avg("avg_seam_anti_sync"),
            "avg_bound_energy":           avg("bound_energy_density"),
            "avg_core_radiation":         avg("core_radiation_potential"),
            "avg_uv_ir_balance":          avg("uv_ir_field_balance"),
            "avg_field_bond_depth":       avg("field_bond_depth"),
            "final_field_bond_depth":     results[-1]["field_bond_depth"],
            "field_radiant_rate":         avg("field_radiant_stable"),
            "field_radiant_rate_tail":    tavg("field_radiant_stable"),
        }


