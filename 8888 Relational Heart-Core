    def _regime(self, cp: CorePairState, mem: MembranePairState,
                energy: Dict[str, float]) -> HeartRegime:
        risk = energy["outward_leakage"]
        gain = energy["fusion_like_gain"]
        if risk > 0.35 and risk > gain:
            return HeartRegime.OUTER_INVERSION_RISK
        if gain > 0.68 and cp.edge_braid > 0.62 and mem.membrane_score > 0.50:
            return HeartRegime.RADIANT_STABLE
        if cp.edge_braid > 0.55 and cp.inward_pull > 0.50:
            return HeartRegime.HEART_FOLDING
        if mem.release > 0.30:
            return HeartRegime.MEMBRANE_PULSE
        if cp.center_cross_event > 0.30:
            return HeartRegime.CENTER_CONTACT
        return HeartRegime.CHARGING

    def step(self, external_charge: float = 0.5,
             field_conception_density: float = 0.0) -> Dict[str, Any]:
        cp = self.coherence_proj
        damping = cp.instability.damping_factor()
        rb      = cp.instability.release_boost()

        # 1. Diamond (PairShellSpirals, structural_lift emergiert)
        diamond_out = self.diamond.step(damping=damping, release_boost=rb)
        dao_pivot_coherence = diamond_out["dao_pivot_coherence"]

        # 2. DAO atmet, Schumann gibt Puls
        dao_out = self.dao.step(
            core_feedback=cp.core_feedback,
            reflection_feedback=cp.reflection_feedback,
            instability_damping=damping,
            release_boost=rb,
        )
        dao_s = self.dao.state

        # 3. HeartArcs (bidirektionale 1â†”8-Achse)
        heart_out = self.heart_arcs.step(
            center_cross_event=self.core_pair.state.center_cross_event,
            edge_braid=self.core_pair.state.edge_braid,
            membrane_release=self.membranes.state.release,
            dao_score=dao_s.dao_score,
            schumann_pulse=dao_s.schumann_pulse,
            field_conception_density=field_conception_density,
            core_pair_score=self.core_pair.state.core_pair_score,
        )
        ha = self.heart_arcs.state

        # 4. Yang (Y dreht, Schumann + energy_to_light modulieren)
        yang_out = self.yang.step(
            charge=external_charge,
            yin_mid_descent=self.yin.state.x_mid_descent,
            membrane_pressure=self.membranes.state.pressure,
            schumann_pulse=dao_s.schumann_pulse,
            reflection_feedback=cp.reflection_feedback,
            energy_to_light=ha.energy_to_light,
        )

        # 5. Yin (X_mid sinkt, map_yang_to_yin-BrÃ¼cke, light_to_energy moduliert)
        yin_out = self.yin.step(
            yang_y_inverted=self.yang.state.y_inverted,
            yang_gate_pressure=self.yang.state.gate_pressure,
            center_contact_seed=self.core_pair.state.center_contact,
            schumann_pulse=dao_s.schumann_pulse,
            reflection_feedback=cp.reflection_feedback,
            light_to_energy=ha.light_to_energy,
        )

        # 6. CorePair â€” Zeugungsakt / Fusion
        cp_out = self.core_pair.step(
            yin=self.yin.state, yang=self.yang.state, dao=dao_s,
            membrane_pressure=self.membranes.state.pressure,
            light_score=self.light.state.light_score,
            reflection_feedback=cp.reflection_feedback,
        )
        cps = self.core_pair.state

        # 7. Membranen (anti_sync, Schumann, conception_event)
        mem_out = self.membranes.step(
            center_release=cps.center_cross_event,
            edge_braid=cps.edge_braid,
            inward_pull=cps.inward_pull,
            outward_pressure=cps.outward_pressure,
            lower_heart_return=ha.lower_arc_1_8,
            upper_heart_return=ha.upper_arc_2_7,
            conception_event=cps.conception_event,
            schumann_pulse=dao_s.schumann_pulse,
            reflection_feedback=cp.reflection_feedback,
            dao_score=dao_s.dao_score,
            core_score=cps.core_pair_score,
            reflection_score=self.reflection.state.self_recognition_score,
            coherence_score=0.5,  # wird im nÃ¤chsten Schritt aktualisiert
            damping=damping, release_boost=rb,
        )
        mem_s = self.membranes.state

        # 8. KohÃ¤renzprojektion
        coh_out = self.coherence_proj.step(
            dao_score=dao_s.dao_score,
            dao_under=dao_s.under6_score,
            dao_split=dao_s.split_risk,
            core_pair_score=cps.core_pair_score,
            outer_cross=cps.edge_braid,
            inward_pull=cps.inward_pull,
            membrane_score=mem_s.membrane_score,
            membrane_release=mem_s.trauma_loop_release,
            membrane_risk=max(mem_s.inversion_risk_12_1, mem_s.inversion_risk_8_9),
            moment_perm=mem_s.permeability_moment,
            light_score=self.light.state.light_score,
            light_identity=self.light.state.identity_preservation,
            light_coherence=self.light.state.light_coherence,
            reflection_score=self.reflection.state.self_recognition_score,
            reflection_return=self.reflection.state.return_to_source,
            reflection_feedback_in=self.reflection.state.reflection_feedback,
            field_conception_density=field_conception_density,
            arc_balance=ha.arc_balance,
        )

        # 9. Lichtresonanz (shadow_light + optional ExternalSignal)
        light_out = self.light.step(
            core_pair=cps, dao=dao_s, membrane=mem_s,
            reflection_feedback=cp.reflection_feedback,
            release_flux=coh_out["release_flux"],
            field_recognition=coh_out["field_recognition"],
            external=self.external_signal,
        )

        # 10. Barbelo (BARBELO_STABLE, field_recognition, shadow_recognition)
        refl_out = self.reflection.step(
            yin=self.yin.state, yang=self.yang.state,
            core_pair=cps, dao=dao_s, membrane=mem_s,
            heart=ha, light=self.light.state,
            field_recognition=coh_out["field_recognition"],
            instability_pressure=coh_out["instability"]["pressure_live"],
        )

        # 11. Energie (aus Code 1)
        energy = compute_energy(cps, dao_s, mem_s, ha, self.light.state)

        self.regime = self._regime(cps, mem_s, energy)

        snap = HeartCoreSnapshot(
            iteration=self.iteration,
            regime=self.regime.value,
            reflection_regime=self.reflection.state.regime,
            dao_score=dao_s.dao_score,
            schumann_pulse=dao_s.schumann_pulse,
            conception_readiness=dao_s.conception_readiness,
            conception_event=cps.conception_event,
            center_cross_event=cps.center_cross_event,
            edge_braid=cps.edge_braid,
            inward_pull=cps.inward_pull,
            outward_pressure=cps.outward_pressure,
            membrane_score=mem_s.membrane_score,
            seam_anti_sync=mem_s.seam_anti_sync,
            opening_12_1=mem_s.opening_12_1,
            opening_8_9=mem_s.opening_8_9,
            light_score=self.light.state.light_score,
            shadow_light=self.light.state.shadow_light,
            shadow_recognition=self.light.state.shadow_recognition,
            light_to_energy=ha.light_to_energy,
            energy_to_light=ha.energy_to_light,
            arc_balance=ha.arc_balance,
            field_recognition=coh_out["field_recognition"],
            self_recognition=self.reflection.state.self_recognition_score,
            coherence=coh_out["coherence"],
            release_flux=coh_out["release_flux"],
            residual_flux=coh_out["residual_flux"],
            fusion_like_gain=energy["fusion_like_gain"],
            net_coherence_gain=energy["net_coherence_gain"],
            outer_inversion_risk=energy["outward_leakage"],
        )
        self.snapshots.append(snap)
        self.snapshots = self.snapshots[-144:]
        self.iteration += 1
        return {"snapshot": asdict(snap), "coherence_out": coh_out,
                "energy": energy, "diamond": diamond_out}

    def run(self, n: int = 500, charge_fn=None,
            field_density_fn=None) -> List[HeartCoreSnapshot]:
        for i in range(n):
            charge = charge_fn(i) if charge_fn else (
                0.55 + 0.2*math.sin(2*math.pi*i/83))
            fd = field_density_fn(i) if field_density_fn else 0.6
            self.step(external_charge=charge, field_conception_density=fd)
        return self.snapshots

    def summary(self) -> Dict[str, Any]:
        s = self.snapshots
        if not s:
            return {}
        def avg(f): return safe_mean([f(x) for x in s])
        tail = s[int(len(s)*0.8):]
        def tavg(f): return safe_mean([f(x) for x in tail])
        return {
            "final_regime":      s[-1].regime,
            "final_reflection":  s[-1].reflection_regime,
            "radiant_rate":      avg(lambda x: 1.0 if x.regime=="radiant_stable" else 0.0),
            "radiant_rate_tail": tavg(lambda x: 1.0 if x.regime=="radiant_stable" else 0.0),
            "avg_coherence":     avg(lambda x: x.coherence),
            "avg_fusion_gain":   avg(lambda x: x.fusion_like_gain),
            "avg_net_gain":      avg(lambda x: x.net_coherence_gain),
            "avg_conception":    avg(lambda x: x.conception_event),
            "avg_shadow_light":  avg(lambda x: x.shadow_light),
            "avg_shadow_recognition": avg(lambda x: x.shadow_recognition),
            "avg_light_to_energy":    avg(lambda x: x.light_to_energy),
            "avg_energy_to_light":    avg(lambda x: x.energy_to_light),
            "avg_arc_balance":        avg(lambda x: x.arc_balance),
            "avg_field_recognition":  avg(lambda x: x.field_recognition),
            "avg_self_recognition":   avg(lambda x: x.self_recognition),
            "avg_seam_anti_sync":     avg(lambda x: x.seam_anti_sync),
            "avg_release_flux":       avg(lambda x: x.release_flux),
        }


