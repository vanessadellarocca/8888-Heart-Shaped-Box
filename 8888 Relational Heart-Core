        ])
        s.upper_arc_2_7 = lerp(s.upper_arc_2_7, upper_target, EDGE_RATE)
        s.venus_contact_form = s.upper_arc_2_7

        s.return_force = safe_geomean([
            s.lower_arc_1_8 + EPSILON,
            s.upper_arc_2_7 + EPSILON,
            edge_braid + EPSILON,
        ])
        s.arc_score = safe_geomean([
            s.return_force + EPSILON,
            s.arc_balance + EPSILON,
            s.mars_pluto_transform + EPSILON,
        ])
        return {
            "state": asdict(s),
            "light_to_energy": s.light_to_energy,
            "energy_to_light": s.energy_to_light,
            "arc_balance": s.arc_balance,
        }


