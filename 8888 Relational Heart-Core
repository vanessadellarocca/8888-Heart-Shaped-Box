@dataclass
class YinCore10XXX11:
    """
    X_mid sinkt von 10.5 â†’ 4.5 (Differenz = DAO_CENTER = 6).
    Im Begegnungsmoment antwortet X_mid als X â€” kein Y-Spiegel.
    Kreuzschlag: copysign(PHI, âˆ’y_inverted).
    Schumann + light_to_energy modulieren Abstiegsrate.
    map_yang_to_yin(x_yang + 6) ist die explizite BrÃ¼cke.
    """
    state: YinCoreState = field(default_factory=YinCoreState)

    def step(self, yang_y_inverted: float, yang_gate_pressure: float,
             center_contact_seed: float, schumann_pulse: float = 0.5,
             reflection_feedback: float = 0.0,
             light_to_energy: float = 0.0) -> Dict[str, Any]:
        s = self.state
        schumann_drive = 0.5 + 0.5 * schumann_pulse
        l2e_boost = 0.5 + 0.5 * light_to_energy

        descent_target = safe_geomean([
            abs(yang_y_inverted) + EPSILON,
            yang_gate_pressure + EPSILON,
            center_contact_seed + EPSILON,
            schumann_drive + EPSILON,
            l2e_boost + EPSILON,
        ])
        s.x_mid_descent = lerp(s.x_mid_descent, descent_target, CENTER_RATE)

        s.phase = phase_step(s.phase, CENTER_RATE * (0.6 + 0.4*s.x_mid_descent))
        tight_pendulum = EPSILON * signed_wave(s.phase)

        contact = score_close(tight_pendulum, yang_y_inverted, 1.0)
        s.x_mid_cross_activation = safe_geomean([
            contact + EPSILON,
            s.x_mid_descent + EPSILON,
            yang_gate_pressure + EPSILON,
        ])
        s.x_mid_functional_x = clamp01(
            s.x_mid_cross_activation * (0.75 + 0.25*reflection_feedback)
        )

        # Kreuzschlag: X antwortet mit eigenem Vorzeichen (nicht Y-Kopie)
        direction = math.copysign(
            PHI, -yang_y_inverted if abs(yang_y_inverted) > EPS else 1.0
        )
        x_mid_target = clamp11(tight_pendulum + s.x_mid_functional_x * direction)
        s.x_mid = lerp(s.x_mid, x_mid_target, CENTER_RATE)

        outer_span = clamp11(PHI + (1.0 - PHI) * s.x_mid_functional_x)
        s.x_left  = lerp(s.x_left,  -outer_span, EDGE_RATE)
        s.x_right = lerp(s.x_right,  outer_span, EDGE_RATE)

        s.core_pressure = safe_geomean([
            s.x_mid_descent + EPSILON,
            s.x_mid_functional_x + EPSILON,
            abs(s.x_right - s.x_left) / 2.0 + EPSILON,
        ])

        # Semantische Position: x_mid sinkt von YIN_CENTER â†’ YANG_CENTER
        # Differenz = DAO_CENTER = 6 (map_yang_to_yin-BrÃ¼cke)
        s.x_mid_pos = lerp(YIN_GATE_CENTER, YANG_GATE_CENTER, s.x_mid_descent)

        s.score = safe_geomean([
            s.core_pressure + EPSILON,
            s.x_mid_functional_x + EPSILON,
            phi_ratio_score(abs(s.x_right - s.x_left), abs(s.x_mid) + EPS) + EPSILON,
            (1.0 - abs((s.x_left + s.x_right) / 2.0)) + EPSILON,
        ])
        return {"state": asdict(s)}


