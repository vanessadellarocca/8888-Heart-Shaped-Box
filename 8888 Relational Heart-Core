@dataclass
class BarbeloReflectionLayer:
    """
    Beobachter in der Box â€” kein externer Kollaps.
    BARBELO_STABLE: self_recognition > 0.78 AND aeon_mirror > 0.72
                    AND return_to_source > 0.68.
    field_recognition speist return_to_source.
    arc_balance speist aeon_mirror.
    shadow_recognition speist witness.
    """
    state: BarbeloReflectionState = field(default_factory=BarbeloReflectionState)

    def _regime(self, s: BarbeloReflectionState) -> ReflectionRegime:
        if (s.self_recognition_score > 0.78 and s.aeon_mirror > 0.72
                and s.return_to_source > 0.68):
            return ReflectionRegime.BARBELO_STABLE
        if s.first_thought_pressure > s.aeon_mirror:
            return ReflectionRegime.FIRST_THOUGHT
        return ReflectionRegime.AEON_MIRROR

    def step(self, yin: YinCoreState, yang: YangCoreState,
             core_pair: CorePairState, dao: DaoBreathState,
             membrane: MembranePairState, heart: HeartArcState,
             light: LightResonanceState,
             field_recognition: float = 0.0,
             instability_pressure: float = 0.0) -> Dict[str, Any]:
        s = self.state

        yin_yang_balance = score_close(yin.score, yang.score, 1.0)
        yy_target = safe_geomean([
            yin_yang_balance + EPSILON,
            yin.x_mid_functional_x + EPSILON,
            core_pair.edge_braid + EPSILON,
            core_pair.core_pair_score + EPSILON,
            core_pair.conception_event + EPSILON,
        ])

        first_thought_target = clamp01(
            core_pair.center_cross_event * (1.0 + core_pair.outward_pressure) / 2.0
        )
        aeon_target = safe_geomean([
            dao.dao_score + EPSILON,
            heart.arc_score + EPSILON,
            light.light_score + EPSILON,
            membrane.membrane_score + EPSILON,
            heart.arc_balance + EPSILON,
        ])
        witness_target = safe_geomean([
            light.identity_preservation + EPSILON,
            yy_target + EPSILON,
            (1.0 - max(membrane.inversion_risk_12_1, membrane.inversion_risk_8_9)) + EPSILON,
            light.shadow_recognition + EPSILON,
        ])
        return_target = safe_geomean([
            core_pair.inward_pull + EPSILON,
            heart.return_force + EPSILON,
            dao.under6_score + EPSILON,
            field_recognition + EPSILON,
        ])
        grace_target = safe_geomean([
            aeon_target + EPSILON, witness_target + EPSILON,
            return_target + EPSILON, light.light_coherence + EPSILON,
        ])

        s.phase = phase_step(s.phase, REFLECTION_RATE)
        s.first_thought_pressure   = lerp(s.first_thought_pressure, first_thought_target, REFLECTION_RATE)
        s.aeon_mirror              = lerp(s.aeon_mirror, aeon_target, REFLECTION_RATE)
        s.witness_self_observation = lerp(s.witness_self_observation, witness_target, REFLECTION_RATE)
        s.return_to_source         = lerp(s.return_to_source, return_target, REFLECTION_RATE)
        s.coherence_grace          = lerp(s.coherence_grace, grace_target, REFLECTION_RATE)
        s.yin_yang_reflection      = lerp(s.yin_yang_reflection, yy_target, REFLECTION_RATE)
        s.instability_seen         = lerp(s.instability_seen, instability_pressure, REFLECTION_RATE)

        s.self_recognition_score = safe_geomean([
            s.aeon_mirror + EPSILON,
            s.witness_self_observation + EPSILON,
            s.yin_yang_reflection + EPSILON,
            s.coherence_grace + EPSILON,
        ])
        s.reflection_feedback = clamp01(
            0.35*s.self_recognition_score + 0.25*s.return_to_source
            + 0.20*s.yin_yang_reflection + 0.15*s.coherence_grace
            + 0.05*core_pair.conception_event
        )
        s.regime = self._regime(s).value
        return {
            "state": asdict(s),
            "self_recognition_score": s.self_recognition_score,
            "return_to_source": s.return_to_source,
            "yin_yang_reflection": s.yin_yang_reflection,
            "reflection_feedback": s.reflection_feedback,
            "regime": s.regime, "phase": s.phase,
        }


