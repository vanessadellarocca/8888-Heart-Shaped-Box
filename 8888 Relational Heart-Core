        s.mars_pluto_transform = s.lower_arc_1_8

        # arc_balance: phi_ratio(l2e, e2l) â€” Gleichgewicht = PHI
        s.arc_balance = phi_ratio_score(
            s.light_to_energy + EPS, s.energy_to_light + EPS
        )

        # 2â†”7 Venus: Flussufer
        upper_target = safe_geomean([
            membrane_release + EPSILON,
