        s12 = self.seam_12_1.step(
            drive=drive * (0.65 + 0.35*upper_heart_return),
            dao_score=dao_score, core_score=core_score,
            reflection_score=reflection_score, coherence_score=coherence_score,
            damping=damping, release_boost=release_boost,
            schumann_pulse=schumann_pulse, conception_event=conception_event,
            opposite_phase=self.seam_8_9.phase,
        )
        s89 = self.seam_8_9.step(
            drive=drive * (0.65 + 0.35*lower_heart_return),
            dao_score=dao_score, core_score=core_score,
            reflection_score=reflection_score, coherence_score=coherence_score,
            damping=damping, release_boost=release_boost,
            schumann_pulse=schumann_pulse, conception_event=conception_event,
            opposite_phase=self.seam_12_1.phase,
        )

        s.opening_12_1 = s12["permeability_live"]
        s.opening_8_9  = s89["permeability_live"]
        s.seam_anti_sync = safe_mean([s12["anti_sync"], s89["anti_sync"]])

        s.inversion_risk_12_1 = clamp01(s.opening_12_1 * outward_pressure * (1.0 - edge_braid))
        s.inversion_risk_8_9  = clamp01(s.opening_8_9  * outward_pressure * (1.0 - edge_braid))
        max_risk = max(s.inversion_risk_12_1, s.inversion_risk_8_9)

        s.release = safe_geomean([
            s.opening_12_1 + EPSILON, s.opening_8_9 + EPSILON,
            edge_braid + EPSILON, inward_pull + EPSILON,
        ])
        s.permeability_moment = clamp01(s.release * (1.0 - max_risk))
        s.pressure = clamp01(
            outward_pressure * (1.0 - s.release) + center_release * (1.0 - edge_braid)
        )
        s.membrane_score = safe_geomean([
            s.permeability_moment + EPSILON,
            (1.0 - s.inversion_risk_12_1) + EPSILON,
            (1.0 - s.inversion_risk_8_9) + EPSILON,
            s.release + EPSILON,
            s.trauma_loop_release + EPSILON,
            s.seam_anti_sync + EPSILON,
        ])
        return {
            "state": asdict(s),
            "membrane13_score": s.membrane_score,
            "outer_inversion_risk": max_risk,
            "trauma_loop_release": s.trauma_loop_release,
            "moment_as_permeability": s.permeability_moment,
            "seam_anti_sync": s.seam_anti_sync,
        }


