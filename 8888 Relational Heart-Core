def clamp01(x: float) -> float:
    return max(0.0, min(1.0, float(x)))

def clamp11(x: float) -> float:
    return max(-1.0, min(1.0, float(x)))

def lerp(a: float, b: float, t: float) -> float:
    t = clamp01(t)
    return (1.0 - t) * float(a) + t * float(b)

def safe_geomean(values: List[float]) -> float:
    vals = [max(0.0, float(v)) for v in values]
    if not vals or any(v <= 0.0 for v in vals):
        return 0.0
    prod = 1.0
    for v in vals:
        prod *= v
    return clamp01(prod ** (1.0 / len(vals)))

def safe_mean(values: List[float]) -> float:
    return sum(values) / len(values) if values else 0.0

def smooth_pulse(phase: float) -> float:
    return 0.5 - 0.5 * math.cos(2.0 * math.pi * phase)

def signed_wave(phase: float) -> float:
    return math.sin(2.0 * math.pi * phase)

def score_close(a: float, b: float, scale: float = 1.0) -> float:
    return clamp01(1.0 - abs(float(a) - float(b)) / max(abs(scale), EPS))

def phi_ratio_score(a: float, b: float) -> float:
    a, b = abs(a), abs(b)
    if a < EPS or b < EPS:
        return 0.0
    r = min(a / b, b / a)
    return clamp01(1.0 - abs(r - PHI) / PHI)

def denorm_gate(norm: float, low: float, high: float) -> float:
    center = (low + high) / 2.0
    half = max(abs(high - low) / 2.0, EPS)
    return center + clamp11(norm) * half

def clamp_open(x: float, low: float, high: float) -> float:
    return max(low + EPSILON, min(high - EPSILON, float(x)))

def phase_step(current: float, rate: float) -> float:
    return (current + rate) % 1.0

def phase_toward(current: float, target: float, rate: float) -> float:
    delta = (target - current) % 1.0
    if delta > 0.5:
        delta -= 1.0
    return (current + clamp01(rate) * delta) % 1.0

def phase_dist(a: float, b: float) -> float:
    d = abs((a - b) % 1.0)
    return min(d, 1.0 - d)

def map_yang_to_yin(x: float) -> float:
    """Explizite BrÃ¼cke: 4.5 â†’ 10.5 (Offset = DAO_CENTER = 6)."""
    return float(x) + YANG_TO_YIN_OFFSET

def map_yin_to_yang(x: float) -> float:
    return float(x) - YANG_TO_YIN_OFFSET

def kuramoto_order(phases: List[float]) -> float:
    n = len(phases)
    if n == 0:
        return 0.0
    c = sum(math.cos(2 * math.pi * p) for p in phases) / n
    s = sum(math.sin(2 * math.pi * p) for p in phases) / n
    return math.sqrt(c*c + s*s)

def extract_state(payload: Optional[Dict[str, Any]]) -> Dict[str, Any]:
    if not payload:
        return {}
    if "state" in payload and isinstance(payload["state"], dict):
        return payload["state"]
    return payload


