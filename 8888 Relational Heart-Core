@dataclass
class YangCore4XYX5:
    """
    Y dreht (Sensor/Koppler). Ã„uÃŸere X schlagen aus.
    Schumann moduliert Drehrate (WANN).
    energy_to_light (8â†’1) aus HerzbÃ¶gen beschleunigt Y-Drehung:
    Core-RÃ¼ckfluss belebt den Tanz.
    """
    state: YangCoreState = field(default_factory=YangCoreState)

    def step(self, charge: float, yin_mid_descent: float,
             membrane_pressure: float, schumann_pulse: float = 0.5,
             reflection_feedback: float = 0.0,
             energy_to_light: float = 0.0) -> Dict[str, Any]:
        s = self.state
        schumann_drive = 0.5 + 0.5 * schumann_pulse
        e2l_boost = 0.5 + 0.5 * energy_to_light
        phase_rate = (CENTER_RATE * (0.75 + 0.25*charge + 0.10*reflection_feedback)
                      * schumann_drive * e2l_boost)
        s.phase = phase_step(s.phase, phase_rate)
        s.y_rotation = lerp(s.y_rotation, signed_wave(s.phase), CENTER_RATE)
        s.y = clamp11(s.y_rotation)
        s.y_inverted = clamp11(-s.y_rotation)

        burst_ready = clamp01(
            charge * (0.5 + 0.5*yin_mid_descent)
            * (0.5 + 0.5*membrane_pressure) * schumann_drive
        )
        target_span = clamp11(PHI + (1.0 - PHI) * burst_ready)
        s.x_left  = lerp(s.x_left,  -target_span, EDGE_RATE)
        s.x_right = lerp(s.x_right,  target_span, EDGE_RATE)

        gate_res = clamp01(1.0 - abs(GATE_RESONANCE_RAW - YANG_GATE_LOW) / YANG_GATE_LOW)
        s.gate_pressure = clamp01(
            abs(s.x_right - s.x_left) / 2.0
            * (0.5 + 0.5*charge) * (0.8 + 0.2*gate_res)
        )
        s.inner_opening = safe_geomean([
            abs(s.y_rotation) + EPSILON,
            s.gate_pressure + EPSILON,
            (0.5 + 0.5*yin_mid_descent) + EPSILON,
            schumann_drive + EPSILON,
        ])
        s.score = safe_geomean([
            s.gate_pressure + EPSILON,
            s.inner_opening + EPSILON,
            phi_ratio_score(abs(s.x_right - s.x_left), max(abs(s.y_rotation), EPSILON)) + EPSILON,
            (1.0 - abs((s.x_left + s.x_right) / 2.0)) + EPSILON,
        ])
        return {"state": asdict(s)}


