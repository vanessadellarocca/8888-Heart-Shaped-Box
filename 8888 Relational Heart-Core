@dataclass
class PairShellSpiral:
    """
    Ein Paar (a, b) mit a+b = total tanzt um sein Zentrum total/2.
    Im inneren Umkehrpunkt berÃ¼hrt upper_live das Zentrum (Kontakt, kein Sein).
    Das ist die geometrische Grundstruktur â€” gilt fÃ¼r alle Paare im Ring.
    """
    total: float
    pair:  Tuple[float, float]
    name:  str = ""
    phase: float = 0.0
    lower_live: float = 0.0
    upper_live: float = 0.0

    def __post_init__(self):
        a, b = sorted(float(x) for x in self.pair)
        self.pair = (a, b)
        if not self.name:
            self.name = f"{a:g}|{b:g}"
        if self.lower_live == 0.0:
            self.lower_live = a
        if self.upper_live == 0.0:
            self.upper_live = b

    @property
    def center(self) -> float:
        return self.total / 2.0

    @property
    def center_target(self) -> float:
        return self.center - EPSILON

    @property
    def outer_radius(self) -> float:
        a, b = self.pair
        return (b - a) / 2.0

    def dao_radius(self) -> float:
        inward = 0.5 - 0.5 * math.cos(2.0 * math.pi * self.phase)
        return EPSILON + (self.outer_radius - EPSILON) * (1.0 - inward)

    def turn_pressure(self) -> float:
        r = self.dao_radius()
        return clamp01((self.outer_radius - r) / max(self.outer_radius - EPSILON, EPS))

    def step(self, damping: float = 1.0, release_boost: float = 0.0) -> Dict[str, Any]:
        r = self.dao_radius()
        lower_t = self.center - (r + EPSILON)
        upper_t = self.center + (r - EPSILON)
        eff_track = TRACK_RATE * (0.45 + 0.55 * damping)
        lb, ub = self.lower_live, self.upper_live
        self.lower_live = lerp(lb, lower_t, eff_track)
        self.upper_live = lerp(ub, upper_t, eff_track)
        mid = (self.lower_live + self.upper_live) / 2.0
        center_coherence = clamp01(1.0 - abs(mid - self.center_target) /
                                   max(self.outer_radius, EPS))

        radial_velocity = -math.sin(2.0 * math.pi * self.phase)
        p = self.phase
        if abs(p - 0.5) < 1e-3:
            direction = "inner_turn_upper_touches_center"
        elif p < 1e-3 or p > 1.0 - 1e-3:
            direction = "outer_shell_boundary"
        elif p < 0.5:
            direction = "inward"
        else:
            direction = "return_to_shell_boundary"

        eff_phase = PHASE_RATE * (0.90 + 0.10 * release_boost)
        self.phase = phase_step(self.phase, eff_phase)
        return {
            "name": self.name, "total": self.total,
            "lower_live": self.lower_live, "upper_live": self.upper_live,
            "midpoint_live": mid, "center": self.center,
            "center_coherence": center_coherence,
            "turn_pressure": self.turn_pressure(),
            "inversion_free_score": 1.0 if self.lower_live < self.upper_live else 0.0,
            "direction": direction,
            "upper_touches_center": abs(self.upper_live - self.center) < 1e-4,
        }

    def exact_inner_turn(self) -> Dict[str, Any]:
        r = EPSILON
        lower_ideal = self.center - (r + EPSILON)
        upper_ideal = self.center + (r - EPSILON)
        return {
            "name": self.name, "total": self.total,
            "radius": r,
            "lower_ideal": lower_ideal,
            "upper_ideal": upper_ideal,
            "midpoint_ideal": (lower_ideal + upper_ideal) / 2.0,
            "upper_touches_center": abs(upper_ideal - self.center) < 1e-9,
        }


