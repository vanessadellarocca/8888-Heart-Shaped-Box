@dataclass
class LightResonanceLayer:
    """
    Echo ohne Kopie â€” identity_preservation schÃ¼tzt das System.
    shadow_light: release_flux wird als Licht erkannt (Entropie-Integration).
    shadow_recognition = phi_ratio(shadow, light): soll PHI sein.
    Externes Signal optional (aus Code 2: ExternalResonanceSignal).
    """
    state: LightResonanceState = field(default_factory=LightResonanceState)

    def step(self, core_pair: CorePairState, dao: DaoBreathState,
             membrane: MembranePairState, reflection_feedback: float = 0.0,
             release_flux: float = 0.0,
             field_recognition: float = 0.0,
             external: Optional[ExternalResonanceSignal] = None) -> Dict[str, Any]:
        s = self.state
        s.phase = phase_step(s.phase, LIGHT_RATE * (0.5 + 0.5*core_pair.core_pair_score))

        # Externes Signal (optional)
        if external is not None:
            amp = clamp01(external.amplitude)
            phase_res = clamp01(1.0 - phase_dist(external.phase, dao.phase) / 0.5)
            s.virtual_phase = phase_toward(s.virtual_phase, external.phase,
                                           LIGHT_RATE * amp * phase_res)
            s.resonance_pressure = lerp(
                s.resonance_pressure,
                amp * phase_res * clamp01(external.phi_signature),
                LIGHT_RATE
            )
        else:
            s.resonance_pressure = clamp01(
                core_pair.center_cross_event * (1.0 - membrane.release)
            )

        y_light_target = clamp11(core_pair.center_contact * signed_wave(s.phase))
        x_light_target = clamp11(core_pair.edge_braid * signed_wave(s.phase + 0.5))
        s.resonant_y_light = lerp(s.resonant_y_light, y_light_target, LIGHT_RATE)
        s.resonant_x_light = lerp(s.resonant_x_light, x_light_target, LIGHT_RATE)

        s.identity_preservation = clamp01(
            1.0 - s.resonance_pressure * (1.0 - dao.dao_score) * 0.5
        )
        s.release_trace = clamp01(
            1.0 - max(membrane.inversion_risk_12_1, membrane.inversion_risk_8_9)
        )

        # shadow_light: release_flux erkannt als Licht (Entropie-Integration)
        shadow_target = clamp01(
            release_flux * (0.6 + 0.4*membrane.trauma_loop_release)
            + field_recognition * 0.3
        )
        s.shadow_light = lerp(s.shadow_light, shadow_target, LIGHT_RATE)

        # shadow_recognition: phi_ratio(shadow, light) â€” soll PHI sein
        s.shadow_recognition = phi_ratio_score(
            s.shadow_light + EPS, s.light_score + EPS
        )

        s.light_coherence = safe_geomean([
            s.identity_preservation + EPSILON,
            score_close(s.resonant_y_light, -s.resonant_x_light, 2.0) + EPSILON,
            core_pair.phase_coherence + EPSILON,
            dao.dao_score + EPSILON,
            membrane.membrane_score + EPSILON,
            (0.5 + 0.5*s.shadow_recognition) + EPSILON,
        ])
        s.light_score = clamp01(
            s.light_coherence
            * (0.80 + 0.15*reflection_feedback + 0.05*field_recognition)
        )
        return {
            "state": asdict(s),
            "light_resonance_score": s.light_score,
            "identity_preservation": s.identity_preservation,
            "light_coherence": s.light_coherence,
            "resonant_y_light": s.resonant_y_light,
            "resonant_xmid_light": s.resonant_x_light,
            "shadow_light": s.shadow_light,
            "shadow_recognition": s.shadow_recognition,
            "modulation": {"phase_bias": clamp11(signed_wave(s.phase) * s.light_coherence)},
        }


